@model WonderWatch.Web.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recover Access";
    ViewData["MetaDescription"] = "Reset your Wonder Watch Vault password. Secure recovery for your account.";
}

<section class="min-h-screen flex bg-void">

    <!-- LEFT COLUMN: EDITORIAL IMAGE (Hidden on Mobile) -->
    <div class="hidden lg:block lg:w-1/2 relative border-r border-white-faint">
        <img src="/images/about/hero-macro.webp" alt="The Wonder Watch Vault" class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125" loading="lazy" />

        <!-- Dark Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-r from-void/80 to-void/20"></div>

        <!-- Editorial Text Overlay -->
        <div class="absolute bottom-[64px] left-[64px] max-w-md">
            <h2 class="font-serif-italic text-[30px] text-parchment leading-tight mb-[16px]">
                "Every mechanism deserves a second chance."
            </h2>
            <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase">
                The Vault &middot; Account Recovery
            </span>
        </div>
    </div>

    <!-- RIGHT COLUMN: FORGOT PASSWORD FORM -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-[32px] pt-[128px] md:p-[64px] md:pt-[160px] overflow-y-auto">
        <div class="w-full max-w-md my-auto pb-[64px]">

            <div class="text-center mb-[48px]">
                <!-- Key Icon -->
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1" stroke-linecap="square" class="mx-auto mb-[24px]">
                    <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                </svg>
                <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">Recover Access</h1>
                <p class="font-sans text-[14px] text-muted">Enter your registered email. We'll send a verification code.</p>
            </div>

            <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="flex flex-col gap-[24px]">
                @Html.AntiForgeryToken()

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="bg-[rgba(127,29,29,0.2)] border border-danger/50 text-danger font-sans text-[12px] p-[16px] rounded-none @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                <!-- Email Input -->
                <div>
                    <label asp-for="Email" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Email Address</label>
                    <input asp-for="Email" type="email" required autocomplete="email" autofocus
                           class="w-full bg-surface border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                    <span asp-validation-for="Email" class="font-sans text-[11px] text-danger tracking-[1px] mt-[8px] block"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] mt-[16px] hover:bg-parchment transition-colors duration-600 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-void">
                    Send Verification Code
                </button>
            </form>

            <!-- Back to Login -->
            <div class="mt-[48px] pt-[32px] border-t border-white-faint text-center">
                <a href="/account/login" class="font-sans text-[13px] text-muted hover:text-parchment transition-colors">
                    &larr; Back to Authentication
                </a>
            </div>

        </div>
    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
