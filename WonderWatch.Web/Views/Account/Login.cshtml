@model WonderWatch.Web.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Authenticate";
    ViewData["MetaDescription"] = "Access your Wonder Watch Vault. Secure authentication for our exclusive horological society.";
}

<section class="min-h-screen pt-[131px] flex bg-void">
    
    <!-- LEFT COLUMN: EDITORIAL IMAGE (Hidden on Mobile) -->
    <div class="hidden lg:block lg:w-1/2 relative border-r border-white-faint">
        <img src="/images/brand/login-bg.webp" alt="The Wonder Watch Vault" class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125" loading="lazy" />
        
        <!-- Dark Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-r from-void/80 to-void/20"></div>
        
        <!-- Editorial Text Overlay -->
        <div class="absolute bottom-[64px] left-[64px] max-w-md">
            <h2 class="font-serif-italic text-[30px] text-parchment leading-tight mb-[16px]">
                "Time is the ultimate currency. Guard it fiercely."
            </h2>
            <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase">
                The Vault &middot; Secure Access
            </span>
        </div>
    </div>

    <!-- RIGHT COLUMN: AUTHENTICATION FORM -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-[32px] md:p-[64px]">
        <div class="w-full max-w-md">
            
            <div class="text-center mb-[48px]">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1" stroke-linecap="square" class="mx-auto mb-[24px]">
                    <rect x="3" y="11" width="18" height="11" rx="0" ry="0"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
                <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">Authenticate</h1>
                <p class="font-sans text-[14px] text-muted">Enter your credentials to access The Vault.</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="flex flex-col gap-[24px]">
                @Html.AntiForgeryToken()

                <!-- Global Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="bg-[rgba(127,29,29,0.2)] border border-danger/50 text-danger font-sans text-[12px] p-[16px] rounded-none @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                <!-- Email Input -->
                <div>
                    <label asp-for="Email" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Email Address</label>
                    <input asp-for="Email" type="email" required autocomplete="email" autofocus
                           class="w-full bg-surface border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                    <span asp-validation-for="Email" class="font-sans text-[11px] text-danger tracking-[1px] mt-[8px] block"></span>
                </div>

                <!-- Password Input -->
                <div>
                    <div class="flex items-center justify-between mb-[8px]">
                        <label asp-for="Password" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase block">Password</label>
                        <a href="/account/forgot-password" class="font-sans font-bold text-[10px] text-gold-dim tracking-[1px] uppercase hover:text-gold transition-colors">Forgot?</a>
                    </div>
                    <input asp-for="Password" type="password" required autocomplete="current-password"
                           class="w-full bg-surface border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                    <span asp-validation-for="Password" class="font-sans text-[11px] text-danger tracking-[1px] mt-[8px] block"></span>
                </div>

                <!-- Remember Me Checkbox -->
                <div class="flex items-center gap-[12px] mt-[8px]">
                    <div class="relative flex items-center justify-center">
                        <input asp-for="RememberMe" type="checkbox"
                               class="appearance-none w-4 h-4 border border-white-faint bg-surface checked:border-gold checked:bg-gold transition-colors rounded-none focus:outline-none focus:ring-1 focus:ring-gold focus:ring-offset-2 focus:ring-offset-void cursor-pointer peer" />
                        <svg class="absolute w-3 h-3 text-void pointer-events-none opacity-0 peer-checked:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <label asp-for="RememberMe" class="font-sans text-[14px] text-muted cursor-pointer select-none hover:text-parchment transition-colors">
                        Keep me authenticated
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] mt-[16px] hover:bg-parchment transition-colors duration-600 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-void">
                    Enter Vault
                </button>

            </form>

            <!-- Registration Link -->
            <div class="mt-[48px] pt-[32px] border-t border-white-faint text-center">
                <p class="font-sans text-[14px] text-muted mb-[16px]">Not a member of The Vault?</p>
                <a href="/account/register" class="inline-block border border-gold text-gold font-sans font-bold text-[11px] tracking-[2.2px] uppercase px-[32px] py-[12px] hover:bg-[rgba(201,167,74,0.1)] transition-colors duration-600">
                    Request Access
                </a>
            </div>

        </div>
    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}