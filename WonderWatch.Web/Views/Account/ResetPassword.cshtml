@model WonderWatch.Web.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["MetaDescription"] = "Set a new password for your Wonder Watch Vault account.";
}

<section class="min-h-screen flex bg-void">

    <!-- LEFT COLUMN: EDITORIAL IMAGE (Hidden on Mobile) -->
    <div class="hidden lg:block lg:w-1/2 relative border-r border-white-faint">
        <img src="/images/about/hero-macro.webp" alt="The Wonder Watch Vault" class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125" loading="lazy" />

        <!-- Dark Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-r from-void/80 to-void/20"></div>

        <!-- Editorial Text Overlay -->
        <div class="absolute bottom-[64px] left-[64px] max-w-md">
            <h2 class="font-serif-italic text-[30px] text-parchment leading-tight mb-[16px]">
                "Reinvention is the mark of mastery."
            </h2>
            <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase">
                The Vault &middot; New Credentials
            </span>
        </div>
    </div>

    <!-- RIGHT COLUMN: RESET PASSWORD FORM -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-[32px] pt-[128px] md:p-[64px] md:pt-[160px] overflow-y-auto">
        <div class="w-full max-w-md my-auto pb-[64px]">

            <div class="text-center mb-[48px]">
                <!-- Lock Reset Icon -->
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1" stroke-linecap="square" class="mx-auto mb-[24px]">
                    <rect x="3" y="11" width="18" height="11" rx="0" ry="0"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    <circle cx="12" cy="16" r="1"></circle>
                </svg>
                <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">New Password</h1>
                <p class="font-sans text-[14px] text-muted">Set a new password for <span class="text-parchment font-medium">@Model.Email</span>.</p>
            </div>

            <form asp-controller="Account" asp-action="ResetPassword" method="post" class="flex flex-col gap-[24px]">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="bg-[rgba(127,29,29,0.2)] border border-danger/50 text-danger font-sans text-[12px] p-[16px] rounded-none @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                <!-- New Password -->
                <div>
                    <label asp-for="NewPassword" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">New Password <span class="text-danger">*</span></label>
                    <input asp-for="NewPassword" type="password" required autocomplete="new-password" autofocus
                           class="w-full bg-surface border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                    <span asp-validation-for="NewPassword" class="font-sans text-[11px] text-danger tracking-[1px] mt-[8px] block"></span>
                </div>

                <!-- Confirm New Password -->
                <div>
                    <label asp-for="ConfirmNewPassword" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Confirm Password <span class="text-danger">*</span></label>
                    <input asp-for="ConfirmNewPassword" type="password" required autocomplete="new-password"
                           class="w-full bg-surface border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                    <span asp-validation-for="ConfirmNewPassword" class="font-sans text-[11px] text-danger tracking-[1px] mt-[8px] block"></span>
                </div>

                <!-- Password Requirements -->
                <div class="bg-surface border border-white-faint p-[16px]">
                    <p class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px]">Requirements</p>
                    <ul class="font-sans text-[12px] text-muted space-y-[4px] list-none">
                        <li class="flex items-center gap-[8px]">
                            <span class="text-gold text-[8px]">&#9670;</span> Minimum 8 characters
                        </li>
                        <li class="flex items-center gap-[8px]">
                            <span class="text-gold text-[8px]">&#9670;</span> At least one uppercase letter
                        </li>
                        <li class="flex items-center gap-[8px]">
                            <span class="text-gold text-[8px]">&#9670;</span> At least one digit
                        </li>
                        <li class="flex items-center gap-[8px]">
                            <span class="text-gold text-[8px]">&#9670;</span> At least one special character
                        </li>
                    </ul>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] mt-[8px] hover:bg-parchment transition-colors duration-600 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-void">
                    Set New Password
                </button>
            </form>

            <!-- Back to Login -->
            <div class="mt-[48px] pt-[32px] border-t border-white-faint text-center">
                <a href="/account/login" class="font-sans text-[13px] text-muted hover:text-parchment transition-colors">
                    &larr; Back to Authentication
                </a>
            </div>

        </div>
    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
