@model WonderWatch.Web.ViewModels.VerifyOtpViewModel
@{
    ViewData["Title"] = "Verify Identity";
    ViewData["MetaDescription"] = "Enter your verification code to access The Vault.";
    var isPasswordReset = Model.Purpose == "password-reset";
    var resendMsg = TempData["ResendSuccess"]?.ToString();
}

<section class="min-h-screen flex bg-void">

    <!-- LEFT COLUMN: EDITORIAL IMAGE (Hidden on Mobile) -->
    <div class="hidden lg:block lg:w-1/2 relative border-r border-white-faint">
        <img src="/images/about/hero-macro.webp" alt="The Wonder Watch Vault" class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125" loading="lazy" />

        <!-- Dark Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-r from-void/80 to-void/20"></div>

        <!-- Editorial Text Overlay -->
        <div class="absolute bottom-[64px] left-[64px] max-w-md">
            <h2 class="font-serif-italic text-[30px] text-parchment leading-tight mb-[16px]">
                "Precision begins with identity."
            </h2>
            <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase">
                The Vault &middot; Verification
            </span>
        </div>
    </div>

    <!-- RIGHT COLUMN: OTP FORM -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-[32px] pt-[128px] md:p-[64px] md:pt-[160px] overflow-y-auto">
        <div class="w-full max-w-md my-auto pb-[64px]">

            <div class="text-center mb-[48px]">
                <!-- Shield Icon -->
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1" stroke-linecap="square" class="mx-auto mb-[24px]">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">
                    @(isPasswordReset ? "Verify Code" : "Verify Identity")
                </h1>
                <p class="font-sans text-[14px] text-muted">
                    We've sent a 6-digit code to <span class="text-parchment font-medium">@Model.Email</span>.
                </p>
            </div>

            <!-- Resend Success Message -->
            @if (!string.IsNullOrEmpty(resendMsg))
            {
                <div class="bg-[rgba(34,197,94,0.1)] border border-green-500/30 text-green-400 font-sans text-[12px] p-[16px] rounded-none mb-[24px] text-center">
                    @resendMsg
                </div>
            }

            <form asp-controller="Account" asp-action="VerifyOtp" method="post" id="otp-form" class="flex flex-col gap-[24px]">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Purpose" />

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="bg-[rgba(127,29,29,0.2)] border border-danger/50 text-danger font-sans text-[12px] p-[16px] rounded-none @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                <!-- OTP Input: 6 Boxes -->
                <div>
                    <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[16px] block text-center">Verification Code</label>
                    <div class="flex justify-center gap-[8px] md:gap-[12px]" id="otp-boxes">
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" class="otp-input w-[48px] h-[56px] md:w-[56px] md:h-[64px] bg-surface border border-white-faint text-parchment font-sans font-bold text-[24px] text-center focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" data-index="0" autocomplete="off" />
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" class="otp-input w-[48px] h-[56px] md:w-[56px] md:h-[64px] bg-surface border border-white-faint text-parchment font-sans font-bold text-[24px] text-center focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" data-index="1" autocomplete="off" />
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" class="otp-input w-[48px] h-[56px] md:w-[56px] md:h-[64px] bg-surface border border-white-faint text-parchment font-sans font-bold text-[24px] text-center focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" data-index="2" autocomplete="off" />
                        <div class="flex items-center"><span class="text-white-faint text-[20px]">&mdash;</span></div>
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" class="otp-input w-[48px] h-[56px] md:w-[56px] md:h-[64px] bg-surface border border-white-faint text-parchment font-sans font-bold text-[24px] text-center focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" data-index="3" autocomplete="off" />
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" class="otp-input w-[48px] h-[56px] md:w-[56px] md:h-[64px] bg-surface border border-white-faint text-parchment font-sans font-bold text-[24px] text-center focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" data-index="4" autocomplete="off" />
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" class="otp-input w-[48px] h-[56px] md:w-[56px] md:h-[64px] bg-surface border border-white-faint text-parchment font-sans font-bold text-[24px] text-center focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" data-index="5" autocomplete="off" />
                    </div>
                    <!-- Hidden real OTP field -->
                    <input type="hidden" asp-for="Otp" id="otp-hidden" />
                    <span asp-validation-for="Otp" class="font-sans text-[11px] text-danger tracking-[1px] mt-[8px] block text-center"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" id="otp-submit" class="w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] mt-[8px] hover:bg-parchment transition-colors duration-600 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-void disabled:opacity-40 disabled:cursor-not-allowed" disabled>
                    Verify Code
                </button>
            </form>

            <!-- Resend Section -->
            <div class="mt-[32px] text-center">
                <p class="font-sans text-[13px] text-muted mb-[12px]">Didn't receive the code?</p>
                <form asp-controller="Account" asp-action="ResendOtp" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="email" value="@Model.Email" />
                    <input type="hidden" name="purpose" value="@Model.Purpose" />
                    <button type="submit" id="resend-btn" class="font-sans font-bold text-[11px] text-gold tracking-[1.5px] uppercase hover:text-parchment transition-colors border-b border-gold/30 hover:border-parchment pb-[2px] disabled:opacity-40 disabled:cursor-not-allowed">
                        Resend Code
                    </button>
                </form>
                <p id="resend-timer" class="font-sans text-[11px] text-muted mt-[8px] hidden">
                    Request new code in <span id="timer-countdown" class="text-gold font-bold">60</span>s
                </p>
            </div>

            <!-- Back Link -->
            <div class="mt-[48px] pt-[32px] border-t border-white-faint text-center">
                <a href="/account/login" class="font-sans text-[13px] text-muted hover:text-parchment transition-colors">
                    &larr; Back to Authentication
                </a>
            </div>

        </div>
    </div>

</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const inputs = document.querySelectorAll('.otp-input');
            const hidden = document.getElementById('otp-hidden');
            const submitBtn = document.getElementById('otp-submit');
            const resendBtn = document.getElementById('resend-btn');
            const timerEl = document.getElementById('resend-timer');
            const countdownEl = document.getElementById('timer-countdown');

            // Focus first input
            inputs[0]?.focus();

            function collectOtp() {
                let otp = '';
                inputs.forEach(i => otp += i.value);
                hidden.value = otp;
                submitBtn.disabled = otp.length !== 6;
            }

            inputs.forEach((input, idx) => {
                input.addEventListener('input', (e) => {
                    const val = e.target.value.replace(/\D/g, '');
                    e.target.value = val.charAt(0) || '';
                    if (val && idx < inputs.length - 1) {
                        inputs[idx + 1].focus();
                    }
                    collectOtp();
                });

                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                        inputs[idx - 1].focus();
                        inputs[idx - 1].value = '';
                        collectOtp();
                    }
                });

                // Handle paste
                input.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const pasted = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 6);
                    pasted.split('').forEach((ch, i) => {
                        if (inputs[i]) inputs[i].value = ch;
                    });
                    if (pasted.length > 0) {
                        const focusIdx = Math.min(pasted.length, inputs.length - 1);
                        inputs[focusIdx].focus();
                    }
                    collectOtp();
                });
            });

            // Resend cooldown timer (60 seconds)
            let cooldown = 60;
            function startCooldown() {
                resendBtn.disabled = true;
                timerEl.classList.remove('hidden');
                const interval = setInterval(() => {
                    cooldown--;
                    countdownEl.textContent = cooldown;
                    if (cooldown <= 0) {
                        clearInterval(interval);
                        resendBtn.disabled = false;
                        timerEl.classList.add('hidden');
                        cooldown = 60;
                    }
                }, 1000);
            }
            startCooldown();
        });
    </script>
}
