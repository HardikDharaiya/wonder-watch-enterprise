@model WonderWatch.Web.ViewModels.AdminOrderListViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Order Management";

    string GetBadgeClasses(string status)
    {
        return status.ToUpper() switch
        {
            "PAID" or "PROCESSING" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "SHIPPED" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "DELIVERED" or "CONFIRMED" => "bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.2)] text-[#22C55E]",
            "PENDING" => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]",
            "CANCELLED" => "bg-[rgba(127,29,29,0.4)] border border-danger/50 text-danger",
            _ => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]"
        };
    }

    bool IsActiveTab(string tab)
    {
        if (string.IsNullOrEmpty(tab) && string.IsNullOrEmpty(Model.StatusFilter)) return true;
        return string.Equals(tab, Model.StatusFilter, StringComparison.OrdinalIgnoreCase);
    }
}

<div class="p-[16px] md:p-[48px] max-w-[1600px] mx-auto">

    <!-- TOAST NOTIFICATIONS -->
    @if (TempData["OrderSuccess"] != null)
    {
        <div class="mb-[32px] bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.2)] p-[16px] flex items-center gap-[12px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="square"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="font-sans text-[14px] text-[#22C55E]">@TempData["OrderSuccess"]</span>
        </div>
    }
    @if (TempData["OrderError"] != null)
    {
        <div class="mb-[32px] bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.2)] p-[16px] flex items-center gap-[12px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="square"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            <span class="font-sans text-[14px] text-danger">@TempData["OrderError"]</span>
        </div>
    }

    <!-- HEADER & ACTIONS -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-[24px] mb-[32px]">
        <div>
            <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">Order Management</h1>
            <p class="font-sans text-[14px] text-muted">Process acquisitions, update shipping statuses, and manage client fulfillment.</p>
        </div>
        <div class="flex items-center gap-[16px]">
            <a href="/api/admin/export/orders-csv" class="border border-gold text-gold font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[16px] hover:bg-[rgba(201,167,74,0.1)] transition-colors duration-600 whitespace-nowrap text-center">
                Export CSV
            </a>
        </div>
    </div>

    <!-- KPI SUMMARY BAR -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-[16px] md:gap-[24px] mb-[32px]">
        <!-- Total Orders -->
        <div class="bg-surface border border-white-faint p-[24px] group hover:border-gold-faint transition-colors duration-600">
            <p class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px]">Total Orders</p>
            <p class="font-serif text-[32px] text-parchment leading-none">@Model.TotalOrderCount</p>
        </div>
        <!-- Pending -->
        <div class="bg-surface border border-white-faint p-[24px] group hover:border-gold-faint transition-colors duration-600">
            <p class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px]">Pending</p>
            <p class="font-serif text-[32px] text-gold leading-none">@Model.PendingCount</p>
        </div>
        <!-- Processing / Shipped -->
        <div class="bg-surface border border-white-faint p-[24px] group hover:border-gold-faint transition-colors duration-600">
            <p class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px]">In Transit</p>
            <p class="font-serif text-[32px] text-parchment leading-none">@(Model.ProcessingCount + Model.ShippedCount)</p>
        </div>
        <!-- Delivered -->
        <div class="bg-surface border border-white-faint p-[24px] group hover:border-gold-faint transition-colors duration-600">
            <p class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px]">Delivered</p>
            <p class="font-serif text-[32px] text-[#22C55E] leading-none">@Model.DeliveredCount</p>
        </div>
    </div>

    <!-- STATUS FILTER TABS -->
    <div class="flex items-center gap-[4px] mb-[24px] overflow-x-auto pb-[4px] border-b border-white-faint">
        <a href="/admin/orders" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("") ? "text-gold border-gold" : "text-muted border-transparent hover:text-parchment")">
            All
        </a>
        <a href="/admin/orders?status=Pending" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("Pending") ? "text-gold border-gold" : "text-muted border-transparent hover:text-parchment")">
            Pending
        </a>
        <a href="/admin/orders?status=Paid" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("Paid") ? "text-gold border-gold" : "text-muted border-transparent hover:text-parchment")">
            Paid
        </a>
        <a href="/admin/orders?status=Processing" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("Processing") ? "text-gold border-gold" : "text-muted border-transparent hover:text-parchment")">
            Processing
        </a>
        <a href="/admin/orders?status=Shipped" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("Shipped") ? "text-gold border-gold" : "text-muted border-transparent hover:text-parchment")">
            Shipped
        </a>
        <a href="/admin/orders?status=Delivered" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("Delivered") ? "text-gold border-gold" : "text-muted border-transparent hover:text-parchment")">
            Delivered
        </a>
        <a href="/admin/orders?status=Cancelled" class="px-[16px] py-[12px] font-sans font-bold text-[10px] tracking-[2px] uppercase transition-colors duration-300 border-b-2 whitespace-nowrap @(IsActiveTab("Cancelled") ? "text-danger border-danger" : "text-muted border-transparent hover:text-parchment")">
            Cancelled
        </a>
    </div>

    <!-- BULK ACTIONS BAR (wrapped in form) -->
    <form id="bulkForm" method="post" action="/admin/orders/bulk-update-status">
        @Html.AntiForgeryToken()

        <div class="bg-surface border border-white-faint border-b-0 p-[24px] flex flex-col md:flex-row items-center justify-between gap-[24px]">
            <div class="flex items-center gap-[16px]">
                <label class="flex items-center gap-[12px] cursor-pointer group">
                    <input type="checkbox" id="selectAllOrders" class="appearance-none w-4 h-4 border border-white-faint bg-void checked:border-gold checked:bg-gold transition-colors rounded-none focus:ring-1 focus:ring-gold focus:ring-offset-1 focus:ring-offset-surface" />
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase group-hover:text-parchment transition-colors">Select All</span>
                </label>
                <span id="selectedCount" class="font-sans text-[10px] text-muted tracking-[1px] hidden">(<span id="selectedCountVal">0</span> selected)</span>
            </div>
            
            <div class="flex items-center gap-[16px] w-full md:w-auto">
                <div class="relative w-full md:w-[240px]">
                    <select name="newStatus" id="bulkStatusSelect" class="w-full bg-void border border-white-faint text-parchment font-sans text-[12px] px-[16px] py-[12px] appearance-none focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none cursor-pointer">
                        <option value="" disabled selected>Change Status To...</option>
                        <option value="Paid">Paid</option>
                        <option value="Processing">Processing</option>
                        <option value="Shipped">Shipped</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center px-[16px] pointer-events-none text-gold">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                </div>
                <button type="submit" id="applyBulkStatusBtn" class="bg-surface-alt border border-white-faint text-muted font-sans font-bold text-[11px] tracking-[2.2px] uppercase px-[24px] py-[12px] hover:text-gold hover:border-gold-faint transition-colors duration-600 whitespace-nowrap">
                    Apply
                </button>
            </div>
        </div>

        <!-- ORDERS TABLE -->
        <div class="bg-surface border border-white-faint overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[1100px]">
                    <thead>
                        <tr>
                            <th class="p-[24px] border-b border-white-faint w-[48px]"></th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Order No.</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Date</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Customer</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Items</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Total Value</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Payment</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint">Status</th>
                            <th class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase p-[24px] border-b border-white-faint text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Orders.Any())
                        {
                            <tr>
                                <td colspan="9" class="p-[64px] text-center">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8A816C" stroke-width="1" stroke-linecap="square" class="mx-auto mb-[24px]">
                                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                                        <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                                        <line x1="12" y1="22.08" x2="12" y2="12" />
                                    </svg>
                                    <h3 class="font-serif text-[24px] text-parchment mb-[8px]">No Orders Found</h3>
                                    <p class="font-sans text-[14px] text-muted">
                                        @if (!string.IsNullOrEmpty(Model.StatusFilter))
                                        {
                                            <span>No orders match the "<strong class="text-gold">@Model.StatusFilter</strong>" filter.</span>
                                        }
                                        else
                                        {
                                            <span>There are currently no acquisitions in the system.</span>
                                        }
                                    </p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var order in Model.Orders)
                            {
                                <tr class="border-b border-white-faint hover:bg-surface-alt transition-colors duration-600 last:border-0 group">
                                    <!-- Checkbox -->
                                    <td class="p-[24px]">
                                        <input type="checkbox" name="orderIds" value="@order.Id" class="order-checkbox appearance-none w-4 h-4 border border-white-faint bg-void checked:border-gold checked:bg-gold transition-colors rounded-none focus:ring-1 focus:ring-gold focus:ring-offset-1 focus:ring-offset-surface cursor-pointer" />
                                    </td>
                                    
                                    <!-- Order Number -->
                                    <td class="p-[24px]">
                                        <span class="font-mono text-[12px] text-gold">@order.OrderNumber</span>
                                    </td>
                                    
                                    <!-- Date -->
                                    <td class="p-[24px]">
                                        <span class="font-sans text-[14px] text-body">@order.Date.ToString("dd MMM yyyy")</span>
                                        <span class="font-sans text-[10px] text-muted block mt-[4px]">@order.Date.ToString("HH:mm") UTC</span>
                                    </td>
                                    
                                    <!-- Customer -->
                                    <td class="p-[24px]">
                                        <span class="font-sans font-medium text-[14px] text-parchment block line-clamp-1 max-w-[180px]" title="@order.CustomerName">@order.CustomerName</span>
                                        <span class="font-sans text-[10px] text-muted block mt-[2px] line-clamp-1 max-w-[180px]">@order.CustomerEmail</span>
                                    </td>
                                    
                                    <!-- Items Count -->
                                    <td class="p-[24px]">
                                        <span class="font-sans font-bold text-[14px] text-body">@order.ItemCount</span>
                                    </td>
                                    
                                    <!-- Total Value -->
                                    <td class="p-[24px]">
                                        <span class="font-sans font-bold text-[14px] text-gold tracking-[-0.45px]">@order.TotalFormatted</span>
                                    </td>
                                    
                                    <!-- Payment Method -->
                                    <td class="p-[24px]">
                                        @if (order.IsPayOnDelivery)
                                        {
                                            <span class="inline-block px-[8px] py-[2px] rounded-[12px] font-sans font-bold text-[9px] tracking-[0.5px] uppercase bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-muted">PoD</span>
                                        }
                                        else
                                        {
                                            <span class="inline-block px-[8px] py-[2px] rounded-[12px] font-sans font-bold text-[9px] tracking-[0.5px] uppercase bg-[rgba(201,167,74,0.15)] border border-[rgba(201,167,74,0.2)] text-gold">Online</span>
                                        }
                                    </td>
                                    
                                    <!-- Status Badge -->
                                    <td class="p-[24px]">
                                        <span class="inline-block px-[11px] py-[3px] rounded-[12px] font-sans font-bold text-[10px] tracking-[0.5px] uppercase @GetBadgeClasses(order.Status)">
                                            @order.Status
                                        </span>
                                    </td>
                                    
                                    <!-- Actions -->
                                    <td class="p-[24px] text-right">
                                        <div class="flex items-center justify-end gap-[16px] flex-nowrap whitespace-nowrap">
                                            <a href="/admin/orders/detail/@order.Id" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase hover:text-gold transition-colors">
                                                Manage
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const selectAll = document.getElementById('selectAllOrders');
            const checkboxes = document.querySelectorAll('.order-checkbox');
            const countSpan = document.getElementById('selectedCount');
            const countVal = document.getElementById('selectedCountVal');
            const bulkForm = document.getElementById('bulkForm');
            const bulkSelect = document.getElementById('bulkStatusSelect');

            function updateCount() {
                const checked = document.querySelectorAll('.order-checkbox:checked').length;
                if (countSpan && countVal) {
                    countVal.textContent = checked;
                    countSpan.classList.toggle('hidden', checked === 0);
                }
            }

            if (selectAll) {
                selectAll.addEventListener('change', function() {
                    checkboxes.forEach(cb => cb.checked = selectAll.checked);
                    updateCount();
                });
            }

            checkboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    if (!this.checked && selectAll) {
                        selectAll.checked = false;
                    } else if (document.querySelectorAll('.order-checkbox:checked').length === checkboxes.length && selectAll) {
                        selectAll.checked = true;
                    }
                    updateCount();
                });
            });

            // Prevent form submit if no orders selected or no status chosen
            if (bulkForm) {
                bulkForm.addEventListener('submit', function(e) {
                    const checked = document.querySelectorAll('.order-checkbox:checked').length;
                    if (checked === 0) {
                        e.preventDefault();
                        alert('Please select at least one order.');
                        return;
                    }
                    if (!bulkSelect.value) {
                        e.preventDefault();
                        alert('Please choose a status to apply.');
                        return;
                    }
                });
            }
        });
    </script>
}