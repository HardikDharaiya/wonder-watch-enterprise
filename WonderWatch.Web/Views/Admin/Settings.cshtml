@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "System Settings";
}

<div class="p-[32px] md:p-[48px] max-w-[1200px] mx-auto">
    
    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-[24px] mb-[48px]">
        <div>
            <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">System Settings</h1>
            <p class="font-sans text-[14px] text-muted">Configure global store parameters, integrations, and security policies.</p>
        </div>
    </div>

    <form action="/admin/settings/save" method="post" class="flex flex-col gap-[32px]">
        @Html.AntiForgeryToken()

        <!-- GENERAL CONFIGURATION -->
        <div class="bg-surface border border-white-faint p-[32px]">
            <h2 class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] border-b border-white-faint pb-[16px]">General Configuration</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-[24px]">
                <div class="md:col-span-2">
                    <label for="StoreName" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Store Name</label>
                    <input type="text" id="StoreName" name="StoreName" value="Wonder Watch India" required
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>

                <div>
                    <label for="SupportEmail" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Concierge Email</label>
                    <input type="email" id="SupportEmail" name="SupportEmail" value="concierge@wonderwatch.in" required
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>

                <div>
                    <label for="SupportPhone" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Concierge Phone</label>
                    <input type="tel" id="SupportPhone" name="SupportPhone" value="+91 800 123 4567" required
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>
            </div>
        </div>

        <!-- FINANCIAL & TAX -->
        <div class="bg-surface border border-white-faint p-[32px]">
            <h2 class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] border-b border-white-faint pb-[16px]">Financial & Tax</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-[24px]">
                <div>
                    <label for="Currency" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Base Currency</label>
                    <input type="text" id="Currency" name="Currency" value="INR (₹)" readonly
                           class="w-full bg-surface-alt border border-white-faint text-muted font-sans text-[14px] px-[16px] py-[12px] rounded-none cursor-not-allowed" />
                </div>

                <div>
                    <label for="TaxRate" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Default GST Rate (%)</label>
                    <input type="number" id="TaxRate" name="TaxRate" value="18" required step="0.1"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>
            </div>
        </div>

        <!-- INTEGRATIONS & SECRETS -->
        <div class="bg-surface border border-white-faint p-[32px]">
            <h2 class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] border-b border-white-faint pb-[16px]">System Integrations</h2>
            
            <div class="flex flex-col gap-[24px]">
                
                <!-- Razorpay Status -->
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-[16px] p-[16px] border border-white-faint bg-void">
                    <div>
                        <span class="font-sans font-bold text-[12px] text-parchment tracking-[1.2px] uppercase block mb-[4px]">Razorpay Payment Gateway</span>
                        <span class="font-sans text-[12px] text-muted">Handles secure checkout and HMAC-SHA256 verification.</span>
                    </div>
                    <div class="flex items-center gap-[12px]">
                        <span class="w-2 h-2 bg-success rounded-full"></span>
                        <span class="font-mono text-[12px] text-success uppercase tracking-[1px]">Connected</span>
                    </div>
                </div>

                <!-- Azure Key Vault Status -->
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-[16px] p-[16px] border border-white-faint bg-void">
                    <div>
                        <span class="font-sans font-bold text-[12px] text-parchment tracking-[1.2px] uppercase block mb-[4px]">Azure Key Vault</span>
                        <span class="font-sans text-[12px] text-muted">Securely injects IConfiguration secrets at runtime.</span>
                    </div>
                    <div class="flex items-center gap-[12px]">
                        <span class="w-2 h-2 bg-success rounded-full"></span>
                        <span class="font-mono text-[12px] text-success uppercase tracking-[1px]">Active</span>
                    </div>
                </div>

            </div>
        </div>

        <!-- SMTP / MAILKIT EMAIL CONFIGURATION -->
        @if (TempData["SmtpSuccess"] != null)
        {
            <div id="toast-smtp" class="fixed top-[112px] right-[24px] z-[100] bg-[rgba(34,197,94,0.15)] border border-[rgba(34,197,94,0.4)] text-[#22c55e] font-sans text-[13px] px-[24px] py-[14px]">
                @TempData["SmtpSuccess"]
            </div>
        }
        @if (TempData["SmtpError"] != null)
        {
            <div id="toast-smtp-err" class="fixed top-[112px] right-[24px] z-[100] bg-[rgba(248,113,113,0.15)] border border-[rgba(248,113,113,0.4)] text-[#f87171] font-sans text-[13px] px-[24px] py-[14px]">
                @TempData["SmtpError"]
            </div>
        }
        <div class="bg-surface border border-white-faint p-[32px]">
            <div class="flex items-center justify-between mb-[24px] border-b border-white-faint pb-[16px]">
                <h2 class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase">Email Configuration (MailKit / SMTP)</h2>
                <div class="flex items-center gap-[8px]">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1.5" stroke-linecap="square"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <span class="font-sans text-[10px] text-muted tracking-[1px] uppercase">Transactional Email Provider</span>
                </div>
            </div>
            <p class="font-sans text-[12px] text-muted mb-[24px] leading-relaxed">
                Configure SMTP credentials for outbound transactional emails (order confirmations, shipping updates). For Gmail, use an <a href="https://myaccount.google.com/apppasswords" target="_blank" class="text-gold hover:text-parchment transition-colors underline">App Password</a> with 2FA enabled.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-[24px]">
                <div>
                    <label for="SmtpHost" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">SMTP Host</label>
                    <input type="text" id="SmtpHost" name="SmtpHost" value="@(ViewBag.SmtpHost ?? "smtp.gmail.com")" placeholder="smtp.gmail.com"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
                </div>
                <div>
                    <label for="SmtpPort" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">SMTP Port</label>
                    <input type="number" id="SmtpPort" name="SmtpPort" value="@(ViewBag.SmtpPort ?? "587")" placeholder="587"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
                </div>
                <div>
                    <label for="SmtpUsername" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Username / Email</label>
                    <input type="text" id="SmtpUsername" name="SmtpUsername" value="@(ViewBag.SmtpUsername ?? "")" placeholder="your-email@gmail.com"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
                </div>
                <div>
                    <label for="SmtpPassword" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">App Password</label>
                    <div class="relative">
                        <input type="password" id="SmtpPassword" name="SmtpPassword" value="@(ViewBag.SmtpPassword ?? "")" placeholder="xxxx xxxx xxxx xxxx"
                               class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30 pr-[48px]" />
                        <button type="button" onclick="toggleSmtpPwd()" class="absolute right-[12px] top-[50%] translate-y-[-50%] text-muted hover:text-gold transition-colors">
                            <svg id="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                </div>
                <div>
                    <label for="SmtpFromEmail" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">From Email</label>
                    <input type="email" id="SmtpFromEmail" name="SmtpFromEmail" value="@(ViewBag.SmtpFromEmail ?? "")" placeholder="noreply@wonderwatch.in"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
                </div>
                <div>
                    <label for="SmtpFromName" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">From Display Name</label>
                    <input type="text" id="SmtpFromName" name="SmtpFromName" value="@(ViewBag.SmtpFromName ?? "Wonder Watch")" placeholder="Wonder Watch"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
                </div>
            </div>

            <!-- Test Email Row -->
            <div class="mt-[24px] pt-[24px] border-t border-white-faint flex flex-col md:flex-row md:items-end gap-[16px]">
                <div class="flex-grow">
                    <label for="TestEmailTo" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Send Test Email To</label>
                    <input type="email" id="TestEmailTo" name="TestEmailTo" placeholder="test@example.com"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
                </div>
                <button type="submit" formaction="/admin/settings/test-email" class="flex-shrink-0 border border-gold text-gold font-sans font-bold text-[11px] tracking-[1.5px] uppercase px-[32px] py-[14px] hover:bg-[rgba(201,167,74,0.1)] transition-colors duration-300 focus:outline-none">
                    Send Test Email
                </button>
            </div>
        </div>

        <!-- SECURITY & MAINTENANCE -->
        <div class="bg-surface border border-white-faint p-[32px]">
            <h2 class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] border-b border-white-faint pb-[16px]">Security & Maintenance</h2>
            
            <div class="flex flex-col gap-[24px]">
                
                <div class="flex items-center justify-between gap-[24px]">
                    <div>
                        <span class="font-sans font-medium text-[16px] text-parchment block mb-[4px]">Maintenance Mode</span>
                        <span class="font-sans text-[12px] text-muted">Disables public access to the catalog and checkout. Admins can still log in.</span>
                    </div>
                    <!-- Sharp Toggle -->
                    <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                        <input type="checkbox" name="MaintenanceMode" value="true" class="sr-only peer">
                        <div class="w-[40px] h-[20px] bg-surface-alt border border-white-faint peer-focus:outline-none peer-focus:ring-1 peer-focus:ring-gold peer-checked:bg-gold peer-checked:border-gold transition-colors duration-300 rounded-none"></div>
                        <div class="absolute left-[2px] top-[2px] bg-muted peer-checked:bg-void w-[16px] h-[16px] transition-transform duration-300 peer-checked:translate-x-[20px] rounded-none"></div>
                    </label>
                </div>

                <div class="w-full h-[1px] bg-white-faint"></div>

                <div class="flex items-center justify-between gap-[24px]">
                    <div>
                        <span class="font-sans font-medium text-[16px] text-parchment block mb-[4px]">Force Two-Factor Authentication (2FA)</span>
                        <span class="font-sans text-[12px] text-muted">Require all Admin and Platinum tier users to use 2FA.</span>
                    </div>
                    <!-- Sharp Toggle -->
                    <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                        <input type="checkbox" name="Force2FA" value="true" class="sr-only peer" checked>
                        <div class="w-[40px] h-[20px] bg-surface-alt border border-white-faint peer-focus:outline-none peer-focus:ring-1 peer-focus:ring-gold peer-checked:bg-gold peer-checked:border-gold transition-colors duration-300 rounded-none"></div>
                        <div class="absolute left-[2px] top-[2px] bg-muted peer-checked:bg-void w-[16px] h-[16px] transition-transform duration-300 peer-checked:translate-x-[20px] rounded-none"></div>
                    </label>
                </div>

            </div>
        </div>

        <!-- DANGER ZONE -->
        <div class="bg-surface border border-error border-opacity-50 p-[32px]">
            <h2 class="font-sans font-bold text-[11px] text-error tracking-[3.3px] uppercase mb-[24px] border-b border-error/30 pb-[16px]">Danger Zone</h2>
            
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-[24px]">
                <div>
                    <span class="font-sans font-medium text-[16px] text-parchment block mb-[4px]">Factory Reset Database</span>
                    <span class="font-sans text-[12px] text-muted">Drops all tables, re-runs migrations, and seeds initial catalog/admin data. Cannot be undone.</span>
                </div>
                <button type="button" onclick="openResetModal()" class="flex-shrink-0 border border-error text-error font-sans font-bold text-[11px] tracking-[1.5px] uppercase px-[32px] py-[14px] hover:bg-error/10 transition-colors duration-300">
                    Reset Database
                </button>
            </div>
        </div>

        <!-- SUBMIT BAR -->
        <div class="bg-surface border border-white-faint p-[32px] flex items-center justify-end sticky bottom-0 z-40 shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
            <button type="submit" class="bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[48px] py-[20px] hover:bg-parchment transition-colors duration-600 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-surface">
                Save Configuration
            </button>
        </div>

    </form>

    <!-- RESET DATABASE MODAL -->
    <div id="resetModal" class="fixed inset-0 z-[200] hidden items-center justify-center">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-void/80 backdrop-blur-sm" onclick="closeResetModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative bg-surface border border-error p-[40px] max-w-[500px] w-full mx-[24px] shadow-2xl shadow-[rgba(248,113,113,0.2)]">
            <h3 class="font-serif text-[32px] text-error leading-none mb-[16px]">Factory Reset</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed mb-[24px]">
                This action will completely wipe all current data, including orders, users, and watches. It will then reseed the database with factory default values.
            </p>
            <p class="font-sans text-[14px] text-parchment mb-[24px]">
                To confirm, type <strong class="text-error tracking-[1px]">RESET DATABASE</strong> below:
            </p>

            <form action="/admin/settings/reset-database" method="post" class="flex flex-col gap-[24px]">
                @Html.AntiForgeryToken()
                <input type="text" name="confirmationText" id="confirmationText" autocomplete="off"
                       class="w-full bg-void border border-error text-parchment font-sans font-bold text-[16px] px-[16px] py-[12px] focus:outline-none focus:ring-1 focus:ring-error transition-colors rounded-none placeholder:text-muted/30" />
                
                <div class="flex justify-end gap-[16px]">
                    <button type="button" onclick="closeResetModal()" class="text-muted font-sans font-bold text-[11px] tracking-[1.5px] uppercase hover:text-parchment transition-colors px-[24px] focus:outline-none">
                        Cancel
                    </button>
                    <button type="submit" id="confirmResetBtn" disabled
                            class="bg-error text-void font-sans font-bold text-[11px] tracking-[1.5px] uppercase px-[32px] py-[12px] opacity-50 cursor-not-allowed transition-all duration-300 focus:outline-none">
                        Confirm Reset
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleSmtpPwd() {
            const inp = document.getElementById('SmtpPassword');
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
        
        const resetModal = document.getElementById('resetModal');
        const confirmationInput = document.getElementById('confirmationText');
        const confirmResetBtn = document.getElementById('confirmResetBtn');

        function openResetModal() {
            resetModal.classList.remove('hidden');
            resetModal.classList.add('flex');
            confirmationInput.value = '';
            checkConfirmation();
            setTimeout(() => confirmationInput.focus(), 50);
        }

        function closeResetModal() {
            resetModal.classList.add('hidden');
            resetModal.classList.remove('flex');
        }

        function checkConfirmation() {
            if (confirmationInput.value === 'RESET DATABASE') {
                confirmResetBtn.disabled = false;
                confirmResetBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                confirmResetBtn.classList.add('hover:bg-[rgba(248,113,113,0.9)]');
            } else {
                confirmResetBtn.disabled = true;
                confirmResetBtn.classList.add('opacity-50', 'cursor-not-allowed');
                confirmResetBtn.classList.remove('hover:bg-[rgba(248,113,113,0.9)]');
            }
        }

        if (confirmationInput) {
            confirmationInput.addEventListener('input', checkConfirmation);
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[id^="toast-"]').forEach(el => {
                setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 600); }, 4000);
            });
        });
    </script>
</div>