@model WonderWatch.Web.ViewModels.WatchDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    ViewData["MetaDescription"] = Model.Description;
    
    // Server-side mobile check for Three.js initialization logic
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
}

<section class="pt-[131px] min-h-screen bg-void border-b border-white-faint">
    <!-- CSRF Token for Wishlist AJAX -->
    <form id="antiForgeryForm" class="hidden">
        @Html.AntiForgeryToken()
    </form>

    <div class="max-w-[1440px] mx-auto grid grid-cols-1 lg:grid-cols-2">
        
        <!-- LEFT COLUMN: IMAGE PORTRAIT -->
        <div class="relative w-full h-[60vh] lg:h-[calc(100vh-131px)] bg-surface-alt border-r border-white-faint flex flex-col items-center justify-center overflow-hidden group">
            <img src="@Model.ImageUrls.FirstOrDefault()" alt="@Model.Name" class="w-full h-full object-contain p-[32px] drop-shadow-2xl z-20" />
        </div>

        <!-- RIGHT COLUMN: PRODUCT DETAILS -->
        <div class="p-[32px] md:p-[64px] lg:p-[96px] flex flex-col justify-center lg:min-h-[calc(100vh-131px)] animate-fade-in relative">
            
            <!-- Back Navigation -->
            <a href="/catalog" class="absolute top-[32px] left-[32px] md:top-[64px] md:left-[64px] lg:top-[96px] lg:left-[96px] group flex items-center gap-[8px] font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase hover:text-gold transition-colors z-30">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" class="transform group-hover:-translate-x-1 transition-transform">
                    <path d="M19 12H5M12 19l-7-7 7-7" />
                </svg>
                Back to Catalog
            </a>

            <!-- Breadcrumb -->
            <nav class="flex items-center gap-[8px] mb-[32px] mt-[48px]">
                <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase">@Model.Brand</span>
                <span class="text-muted text-[10px]">&slash;</span>
                <span class="font-sans font-bold text-[10px] text-parchment tracking-[2px] uppercase">@Model.ReferenceNumber</span>
            </nav>

            <!-- Header -->
            <div class="mb-[48px]">
                <h1 class="font-serif text-[48px] md:text-[64px] text-parchment tracking-[-1.2px] leading-[1.1] mb-[16px]">@Model.Name</h1>
                <div class="flex items-center gap-[16px]">
                    <span class="font-mono text-[14px] text-muted">REF: @Model.ReferenceNumber</span>
                    @if (Model.IsSoldOut)
                    {
                        <span class="bg-[rgba(127,29,29,0.4)] text-danger font-sans font-bold text-[9px] tracking-[0.9px] uppercase px-[8px] py-[4px]">
                            Sold Out
                        </span>
                    }
                </div>
            </div>

            <!-- Price -->
            <div class="mb-[48px] pb-[48px] border-b border-light-void">
                <div class="flex items-baseline gap-[16px] flex-wrap">
                    <span class="font-sans font-bold text-[24px] md:text-[30px] text-gold tracking-[-1.5px]">@Model.PriceFormatted</span>
                    @if (!string.IsNullOrEmpty(Model.ComparePriceFormatted))
                    {
                        <del class="font-sans text-[14px] md:text-[16px] text-muted tracking-[-0.5px]">@Model.ComparePriceFormatted</del>
                    }
                </div>
                @if (Model.StockQuantity > 0 && Model.StockQuantity <= 4)
                {
                    <span class="block mt-[12px] font-sans font-bold text-[11px] tracking-[1px] uppercase text-danger">Only <span class="text-gold">@Model.StockQuantity</span> remaining worldwide</span>
                }
                <span class="font-sans text-[12px] text-muted block mt-[8px]">Inclusive of all taxes. Free secure shipping within India.</span>
            </div>

            <!-- Description -->
            <div class="mb-[48px]">
                <p class="font-sans text-[14px] text-body leading-relaxed max-w-[90%]">
                    @Model.Description
                </p>
            </div>

            <!-- Specifications Formatted as Luxury Sheet -->
            <div class="flex flex-col gap-[24px] mb-[64px] border-l border-white-faint pl-[24px] ml-[8px]">
                <div class="flex items-end justify-between">
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Case Architecture</span>
                    <span class="font-serif text-[18px] text-parchment tracking-tight">@(Model.CaseSize)mm</span>
                </div>
                <div class="w-full h-[1px] bg-white-faint"></div>
                <div class="flex items-end justify-between">
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Calibre</span>
                    <span class="font-serif text-[18px] text-parchment tracking-tight">@Model.MovementType</span>
                </div>
                <div class="w-full h-[1px] bg-white-faint"></div>
                <div class="flex items-end justify-between">
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Bracelet / Strap</span>
                    <span class="font-serif text-[18px] text-parchment text-right tracking-tight max-w-[60%]">@(string.IsNullOrEmpty(Model.StrapMaterial) ? "Not Specified" : Model.StrapMaterial)</span>
                </div>
                <div class="w-full h-[1px] bg-white-faint"></div>
                <div class="flex items-end justify-between">
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Availability</span>
                    <span class="font-serif text-[18px] text-parchment tracking-tight">@(Model.IsSoldOut ? "Unavailable" : "In Stock")</span>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-[16px]">
                @if (Model.IsSoldOut)
                {
                    <button disabled class="w-full sm:w-auto flex-grow bg-surface border border-white-faint text-muted font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] cursor-not-allowed text-center transition-colors">
                        Out of Stock
                    </button>
                }
                else
                {
                    <button type="button" data-watch-id="@Model.Id" class="js-add-to-cart w-full sm:w-auto flex-grow bg-gold text-void border border-gold font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] hover:bg-[#B39542] hover:border-[#B39542] transition-colors text-center focus:outline-none">
                        Acquire Timepiece
                    </button>
                }

                <button type="button" data-watch-id="@Model.Id" class="js-toggle-wishlist w-full sm:w-auto flex-shrink-0 border border-gold text-gold bg-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] hover:bg-gold hover:text-void transition-colors flex items-center justify-center gap-[12px] focus:outline-none group">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" class="wishlist-icon">
                        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78v0z" />
                    </svg>
                    <span class="wishlist-text">Wishlist</span>
                </button>
            </div>

            <!-- Concierge Note -->
            <div class="mt-[64px] pt-[32px] border-t border-white-faint flex items-start gap-[16px]">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1.5" stroke-linecap="square" class="flex-shrink-0 mt-1 opacity-70">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 16v-4" />
                    <path d="M12 8h.01" />
                </svg>
                <p class="font-sans text-[12px] text-muted leading-relaxed max-w-[80%]">
                    Need assistance? Our Chief Curator is available for private consultations regarding this reference. <a href="/contact" class="text-gold hover:text-parchment transition-colors border-b border-gold/30 hover:border-parchment">Contact Concierge</a>.
                </p>
            </div>

        </div>
    </div>
</section>
