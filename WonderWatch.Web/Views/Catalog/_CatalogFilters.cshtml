@model WonderWatch.Web.ViewModels.CatalogIndexViewModel
@{
    var selectedBrands = Context.Request.Query["brands"].ToArray();
    var selectedSize = Context.Request.Query["size"].ToString();
    var selectedSort = Context.Request.Query["sort"].ToString();
    var selectedStrap = Context.Request.Query["strap"].ToString();
    var searchQuery = Context.Request.Query["searchQuery"].ToString();
    
    if (string.IsNullOrEmpty(selectedSort)) selectedSort = "newest";

    // Dynamic price bounds from FilterConfig (DB-driven)
    long priceFloor = (long)Model.PriceMin;
    long priceCeil  = (long)Model.PriceMax;

    // Parse current price range or use DB defaults
    var minPriceQuery = Context.Request.Query["minPrice"].ToString();
    var maxPriceQuery = Context.Request.Query["maxPrice"].ToString();
    long currentMin = string.IsNullOrEmpty(minPriceQuery) ? priceFloor : long.Parse(minPriceQuery);
    long currentMax = string.IsNullOrEmpty(maxPriceQuery) ? priceCeil  : long.Parse(maxPriceQuery);
}

<style>
    /* Dual Range Slider CSS - Bypasses Tailwind JIT for guaranteed rendering */
    .dual-range {
        position: relative;
        height: 4px;
        background: rgba(255,255,255,0.1);
        margin-top: 16px;
        margin-bottom: 16px;
    }

        .dual-range input[type=range] {
            position: absolute;
            width: 100%;
            top: -5px;
            -webkit-appearance: none;
            appearance: none;
            background: transparent;
            pointer-events: none;
            outline: none;
        }

            .dual-range input[type=range]::-webkit-slider-thumb {
                pointer-events: all;
                width: 14px;
                height: 14px;
                -webkit-appearance: none;
                background: #C9A74A;
                border: 2px solid #0A0A0A;
                cursor: pointer;
                border-radius: 0;
            }

            .dual-range input[type=range]::-moz-range-thumb {
                pointer-events: all;
                width: 14px;
                height: 14px;
                background: #C9A74A;
                border: 2px solid #0A0A0A;
                cursor: pointer;
                border-radius: 0;
            }

    /* Tooltips for Sliders */
    .slider-tooltip {
        position: absolute;
        top: -26px;
        background: #C9A74A;
        color: #0A0A0A;
        padding: 4px 6px;
        font-family: inherit;
        font-size: 10px;
        font-weight: bold;
        letter-spacing: 0.5px;
        border-radius: 2px;
        pointer-events: none;
        transform: translateX(-50%);
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.2s ease;
        z-index: 60;
    }
    .dual-range:hover .slider-tooltip {
        opacity: 1;
    }
    .slider-tooltip::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%);
        border-width: 4px 4px 0;
        border-style: solid;
        border-color: #C9A74A transparent transparent transparent;
    }

    /* Search bar styling */
    .cat-search-input {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.12);
        color: #EAE6DB;
        font-family: inherit;
        font-size: 12px;
        letter-spacing: 0.5px;
        padding: 10px 12px 10px 36px;
        width: 100%;
        outline: none;
        transition: border-color 0.3s ease;
    }
    .cat-search-input::placeholder {
        color: #8A816C;
        font-size: 10px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }
    .cat-search-input:focus {
        border-color: #C9A74A;
    }
</style>

<form method="get" action="/catalog" class="cat-filter-form flex flex-col" style="gap:28px;">

    @* Preserve sort across filter changes *@
    <input type="hidden" name="sort" value="@selectedSort" class="hidden-sort-input" />

    @* ── SEARCH ────────────────────────────────────────────────────────────── *@
    <div>
        <span class="block font-sans font-bold text-muted uppercase mb-3"
              style="font-size:9px; letter-spacing:2.5px;">Search</span>
        <div class="relative">
            <svg class="absolute" style="left:10px; top:50%; transform:translateY(-50%); pointer-events:none;"
                 width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8A816C" stroke-width="2" stroke-linecap="square">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text"
                   name="searchQuery"
                   value="@searchQuery"
                   placeholder="Search watches..."
                   class="cat-search-input focus:ring-1 focus:ring-gold focus:outline-none"
                   autocomplete="off" />
        </div>
    </div>

    @* ── BRANDS (Dynamic from DB) ─────────────────────────────────────────── *@
    <div>
        <span class="block font-sans font-bold text-muted uppercase mb-4"
              style="font-size:9px; letter-spacing:2.5px;">Brands</span>
        <div class="flex flex-col" style="gap:12px;">
            @foreach (var brand in Model.AvailableBrands)
            {
                bool isChecked = selectedBrands.Contains(brand, StringComparer.OrdinalIgnoreCase);
                <label class="flex items-center cursor-pointer group" style="gap:12px;">
                    <span class="relative flex-shrink-0 border transition-colors duration-200"
                          style="width:16px; height:16px; border-color: @(isChecked ? "#C9A74A" : "rgba(255,255,255,0.18)");">
                        
                        <input type="checkbox"
                               name="brands"
                               value="@brand"
                               class="absolute inset-0 opacity-0 w-full h-full cursor-pointer m-0 focus:ring-1 focus:ring-gold focus:outline-none"
                               style="z-index: 50;"
                        @(isChecked ? "checked" : "")
                               onchange="this.nextElementSibling.style.opacity = this.checked ? '1' : '0'; this.parentElement.style.borderColor = this.checked ? '#C9A74A' : 'rgba(255,255,255,0.18)';" />
                        
                        <span class="absolute inset-0 flex items-center justify-center pointer-events-none transition-opacity duration-200"
                              style="opacity: @(isChecked ? "1" : "0"); background-color: #C9A74A; z-index: 10;">
                            <svg style="width:10px;height:10px;color:#0A0A0A;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </span>
                    </span>
                    <span class="font-sans text-muted group-hover:text-parchment transition-colors uppercase"
                          style="font-size:10px; letter-spacing:1.5px;">@brand</span>
                </label>
            }
        </div>
    </div>

    @* ── PRICE RANGE (Dynamic DB Bounds) ─── *@
    <div>
        <span class="block font-sans font-bold text-muted uppercase mb-3"
              style="font-size:9px; letter-spacing:2.5px;">Price Range</span>
        
        <div class="dual-range">
            <div id="range-fill" class="absolute h-full bg-gold" style="left: 0%; width: 100%;"></div>
            <div id="min-tooltip" class="slider-tooltip"></div>
            <div id="max-tooltip" class="slider-tooltip"></div>
            <input type="range" name="minPrice" id="minPrice"
                   min="@priceFloor" max="@priceCeil" step="100000" value="@currentMin">
            <input type="range" name="maxPrice" id="maxPrice"
                   min="@priceFloor" max="@priceCeil" step="100000" value="@currentMax">
        </div>
        
        <div class="flex justify-between font-mono text-[10px] text-muted mt-2">
            <span id="minPriceVal">₹@currentMin.ToString("N0")</span>
            <span id="maxPriceVal">₹@currentMax.ToString("N0")@(currentMax >= priceCeil ? "+" : "")</span>
        </div>
    </div>

    @* ── STRAP MATERIAL (Functional) ──────────────────────────────────────── *@
    <div>
        <span class="block font-sans font-bold text-muted uppercase mb-3"
              style="font-size:9px; letter-spacing:2.5px;">Strap Material</span>
        <div class="flex" style="gap:12px;">
            @foreach (var material in new[] { "Gold", "Steel", "Leather", "Rubber" })
            {
                bool isStrapActive = string.Equals(selectedStrap, material, StringComparison.OrdinalIgnoreCase);
                <label class="relative flex flex-col items-center cursor-pointer group" style="gap:6px;">
                    <input type="radio" name="strap" value="@material.ToLower()" class="sr-only" @(isStrapActive ? "checked" : "")
                           onchange="document.querySelectorAll('.cat-strap-box').forEach(b => { b.style.borderColor='rgba(255,255,255,0.18)'; b.style.transform='scale(1)'; }); document.querySelectorAll('.cat-strap-text').forEach(t => t.style.color='#B4AFA2'); this.nextElementSibling.style.borderColor='#C9A74A'; this.nextElementSibling.style.transform='scale(1.1)'; this.parentElement.querySelector('.cat-strap-text').style.color='#C9A74A';" />
                    
                    <div class="cat-strap-box transition-all duration-300"
                         style="width:32px; height:32px; border: 1px solid @(isStrapActive ? "#C9A74A" : "rgba(255,255,255,0.18)"); transform: @(isStrapActive ? "scale(1.1)" : "scale(1)"); background-color: @(material == "Gold" ? "#C9A74A" : material == "Steel" ? "#5a5a5a" : material == "Leather" ? "#4a3525" : "#1c1c1c");">
                    </div>

                    <span class="cat-strap-text font-sans uppercase transition-colors duration-300 text-center"
                          style="font-size:8px; letter-spacing:1px; color: @(isStrapActive ? "#C9A74A" : "#B4AFA2"); margin-top: 2px;">
                        @material
                    </span>
                </label>
            }
        </div>
    </div>

    @* ── CASE DIAMETER (Dynamic) ───────────────────────────────────────────── *@
    <div>
        <span class="block font-sans font-bold text-muted uppercase mb-3"
              style="font-size:9px; letter-spacing:2.5px;">Case Diameter</span>
        <div class="cat-sizes">
            @foreach (var size in Model.AvailableSizes)
            {
                var sizeString = $"{size}MM";
                bool isActive = selectedSize == sizeString;
                <label class="relative cursor-pointer block">
                    <input type="radio" name="size" value="@sizeString" class="sr-only" @(isActive ? "checked" : "")
                           onchange="document.querySelectorAll('.size-box').forEach(b => { b.style.borderColor='rgba(255,255,255,0.18)'; b.style.color='#B4AFA2'; }); this.nextElementSibling.style.borderColor='#C9A74A'; this.nextElementSibling.style.color='#C9A74A';" />
                    
                    <div class="size-box border font-sans uppercase transition-colors text-center"
                         style="font-size:9px; letter-spacing:1.5px; padding:8px 4px; background:transparent; border-color: @(isActive ? "#C9A74A" : "rgba(255,255,255,0.18)"); color: @(isActive ? "#C9A74A" : "#B4AFA2");">
                        @sizeString
                    </div>
                </label>
            }
        </div>
    </div>

    @* ── APPLY ─────────────────────────────────────────────────────────────── *@
    <button type="submit"
            class="w-full font-sans font-bold text-void uppercase transition-colors hover:bg-parchment"
            style="background:#C9A74A; font-size:11px; letter-spacing:2px; padding:14px; border:none; cursor:pointer; margin-top:4px;">
        Apply Filters
    </button>

    @* Clear link *@
    @if (selectedBrands.Any() || !string.IsNullOrEmpty(selectedSize) || !string.IsNullOrEmpty(selectedStrap) || !string.IsNullOrEmpty(searchQuery) || currentMin > priceFloor || currentMax < priceCeil)
    {
        <a href="/catalog" class="text-center font-sans text-muted hover:text-gold transition-colors"
               style="font-size:10px; letter-spacing:1px; text-decoration:none; margin-top:-8px;">
            Clear all filters
        </a>
    }

</form>

<!-- DUAL SLIDER JAVASCRIPT LOGIC -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('.cat-filter-form');
        const minSlider = document.getElementById('minPrice');
        const maxSlider = document.getElementById('maxPrice');
        const searchInput = form.querySelector('input[name="searchQuery"]');

        form.addEventListener('submit', function() {
            if (minSlider && minSlider.value === minSlider.min) {
                minSlider.removeAttribute('name');
            }
            if (maxSlider && maxSlider.value === maxSlider.max) {
                maxSlider.removeAttribute('name');
            }
            if (searchInput && !searchInput.value.trim()) {
                searchInput.removeAttribute('name');
            }
            const sortInput = form.querySelector('input[name="sort"]');
            if (sortInput && sortInput.value === 'newest') {
                sortInput.removeAttribute('name');
            }
        });
        const rangeFill = document.getElementById('range-fill');
        const minVal = document.getElementById('minPriceVal');
        const maxVal = document.getElementById('maxPriceVal');
        const minTooltip = document.getElementById('min-tooltip');
        const maxTooltip = document.getElementById('max-tooltip');

        if(!minSlider || !maxSlider) return;

        // Format number in Indian locale (lakhs/crores)
        function formatINR(num) {
            return '₹' + Number(num).toLocaleString('en-IN');
        }

        function updateSlider() {
            let min = parseInt(minSlider.value);
            let max = parseInt(maxSlider.value);
            
            // Prevent sliders from crossing over each other
            if (min > max) {
                let tmp = min;
                min = max;
                max = tmp;
            }
            
            const sliderMin = parseInt(minSlider.min);
            const sliderMax = parseInt(maxSlider.max);
            const minPercent = ((min - sliderMin) / (sliderMax - sliderMin)) * 100;
            const maxPercent = ((max - sliderMin) / (sliderMax - sliderMin)) * 100;
            
            rangeFill.style.left = minPercent + '%';
            rangeFill.style.width = (maxPercent - minPercent) + '%';
            
            minTooltip.style.left = minPercent + '%';
            maxTooltip.style.left = maxPercent + '%';
            
            minTooltip.textContent = formatINR(min);
            maxTooltip.textContent = formatINR(max) + (max >= sliderMax ? '+' : '');
            
            minVal.textContent = formatINR(min);
            maxVal.textContent = formatINR(max) + (max >= sliderMax ? '+' : '');
        }

        minSlider.addEventListener('input', updateSlider);
        maxSlider.addEventListener('input', updateSlider);
        
        // Initialize on load
        updateSlider();
    });
</script>