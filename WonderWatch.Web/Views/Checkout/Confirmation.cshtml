@model WonderWatch.Web.ViewModels.OrderConfirmationViewModel
@{
    ViewData["Title"] = "Acquisition Confirmed";
    ViewData["MetaDescription"] = "Your Wonder Watch acquisition has been successfully processed.";

    // Helper to determine exact badge colors based on Section 3 specs
    string GetBadgeClasses(string status)
    {
        return status.ToUpper() switch
        {
            "PAID" or "PROCESSING" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "SHIPPED" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "DELIVERED" => "bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.2)] text-[#22C55E]",
            "PENDING" => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]",
            _ => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]"
        };
    }
}

<section class="pt-[107px] min-h-screen bg-void border-b border-white-faint pb-[96px]">
    <div class="max-w-3xl mx-auto px-[32px] mt-[64px]">
        
        <!-- HEADER -->
        <div class="text-center mb-[64px]">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1" stroke-linecap="square" class="mx-auto mb-[24px]">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[16px] block">Acquisition Successful</span>
            <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[24px]">Thank You.</h1>
            <p class="font-sans text-[14px] text-muted leading-relaxed max-w-lg mx-auto">
                Your order has been received and is currently being prepared by our atelier. A confirmation email has been dispatched to your registered address.
            </p>
        </div>

        <!-- ORDER DOSSIER (Receipt) -->
        <div class="bg-surface border border-gold-faint p-[32px] md:p-[48px] relative overflow-hidden">
            
            <!-- Decorative Corner Accents -->
            <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-gold/30 m-4 pointer-events-none"></div>
            <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-gold/30 m-4 pointer-events-none"></div>

            <!-- Meta Information -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-[24px] pb-[32px] border-b border-white-faint">
                <div>
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase block mb-[8px]">Reference Code</span>
                    <span class="font-mono text-[12px] text-gold">@Model.OrderNumber</span>
                </div>
                <div>
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase block mb-[8px]">Date of Acquisition</span>
                    <span class="font-sans text-[14px] text-parchment">@Model.CreatedAt.ToString("dd MMMM yyyy")</span>
                </div>
                <div>
                    <span class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase block mb-[8px]">Status</span>
                    <!-- ONLY exception to zero border-radius: rounded-[12px] -->
                    <span class="inline-block px-[11px] py-[3px] rounded-[12px] font-sans font-bold text-[10px] tracking-[0.5px] uppercase @GetBadgeClasses(Model.Status)">
                        @Model.Status
                    </span>
                </div>
            </div>

            <!-- Items List -->
            <div class="py-[32px] border-b border-white-faint flex flex-col gap-[24px]">
                <span class="font-sans font-bold text-[11px] text-gold tracking-[2.2px] uppercase mb-[8px] block">Acquired Masterpieces</span>
                
                @foreach (var item in Model.Items)
                {
                    <div class="flex items-center gap-[24px]">
                        <div class="w-[64px] h-[80px] bg-surface-alt border border-white-faint p-[8px] flex-shrink-0">
                            <img src="@item.ImageUrl" alt="@item.WatchName" class="w-full h-full object-contain drop-shadow-lg" />
                        </div>
                        <div class="flex flex-col flex-grow">
                            <span class="font-sans font-bold text-[9px] text-gold tracking-[2px] uppercase mb-[4px]">@item.Brand</span>
                            <span class="font-sans font-medium text-[16px] text-parchment leading-tight">@item.WatchName</span>
                            <span class="font-sans text-[12px] text-muted mt-[4px]">Qty: @item.Quantity</span>
                        </div>
                        <div class="text-right">
                            <span class="font-sans font-bold text-[14px] text-parchment">@item.TotalFormatted</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary & Shipping -->
            <div class="pt-[32px] grid grid-cols-1 md:grid-cols-2 gap-[48px]">
                
                <!-- Shipping Details -->
                <div>
                    <span class="font-sans font-bold text-[11px] text-gold tracking-[2.2px] uppercase mb-[16px] block">Dispatch Destination</span>
                    <p class="font-sans text-[14px] text-muted leading-relaxed">
                        @Model.ShippingAddress
                    </p>
                    <p class="font-sans text-[12px] text-muted mt-[16px] italic">
                        * Signature required upon delivery.
                    </p>
                </div>

                <!-- Totals -->
                <div class="flex flex-col gap-[12px]">
                    <div class="flex justify-between items-center">
                        <span class="font-sans text-[14px] text-muted">Subtotal</span>
                        <span class="font-sans font-bold text-[14px] text-parchment">@Model.TotalFormatted</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="font-sans text-[14px] text-muted">Insured Shipping</span>
                        <span class="font-sans font-bold text-[14px] text-parchment">Complimentary</span>
                    </div>
                    <div class="flex justify-between items-center mt-[12px] pt-[24px] border-t border-white-faint">
                        <span class="font-sans font-bold text-[14px] text-parchment uppercase tracking-[1px]">Total Settled</span>
                        <span class="font-sans font-bold text-[24px] text-gold tracking-[-0.45px]">@Model.TotalFormatted</span>
                    </div>
                </div>

            </div>
        </div>

        <!-- ACTIONS -->
        <div class="mt-[48px] flex flex-col sm:flex-row items-center justify-center gap-[24px]">
            <a href="/vault/orders" class="w-full sm:w-auto bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[48px] py-[20px] text-center hover:bg-parchment transition-colors duration-600">
                View in Vault
            </a>
            <a href="/catalog" class="w-full sm:w-auto border border-gold text-gold font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[48px] py-[20px] text-center hover:bg-[rgba(201,167,74,0.1)] transition-colors duration-600">
                Continue Browsing
            </a>
        </div>

    </div>
</section>