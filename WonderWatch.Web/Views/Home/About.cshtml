@{
    ViewData["Title"] = "The Philosophy";
    ViewData["MetaDescription"] = "Learn about Wonder Watch, India's premier dark-luxury horological boutique. Discover our philosophy, craftsmanship, and the atelier.";
}

<!-- HERO SECTION -->
<section class="relative w-full h-[80vh] min-h-[600px] flex items-center justify-center border-b border-white-faint overflow-hidden">
    <!-- Macro Image Background -->
    <div class="absolute inset-0 z-0">
        <img src="/images/about/hero-macro.webp" alt="Obsessed with the Mechanical" class="w-full h-full object-cover opacity-30" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-void via-transparent to-void hover:bg-transparent transition-colors duration-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto text-center px-[32px] pt-[80px]">
        <h1 class="font-serif-italic text-[64px] md:text-[96px] text-white tracking-[-2px] leading-tight mb-[24px]">
            Obsessed with the Mechanical.
        </h1>
        <p class="font-sans text-[16px] text-body leading-relaxed max-w-2xl mx-auto">
            Wonder Watch was established with a singular, uncompromising vision: to curate and forge horological masterpieces for India's most discerning collectors. We do not sell watches; we broker relationships with time.
        </p>
    </div>
</section>

<!-- CORE VALUES (I, II, III) -->
<section class="py-[128px] px-[32px] md:px-[64px] max-w-7xl mx-auto border-b border-white-faint">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[64px]">
        
        <!-- Value 1 -->
        <div class="flex flex-col border-t border-gold-faint pt-[32px] group">
            <span class="font-serif-italic text-[64px] text-gold opacity-50 group-hover:opacity-100 transition-opacity duration-600 mb-[16px] leading-none">I.</span>
            <h3 class="font-serif text-[24px] text-gold mb-[16px]">Our Curation Philosophy</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed">
                Every reference in our catalog is subjected to a rigorous curation process. We reject the superfluous and favor rare materials, prioritizing architectural presence and undeniable weight on the wrist.
            </p>
        </div>

        <!-- Value 2 -->
        <div class="flex flex-col border-t border-gold-faint pt-[32px] group">
            <span class="font-serif-italic text-[64px] text-gold opacity-50 group-hover:opacity-100 transition-opacity duration-600 mb-[16px] leading-none">II.</span>
            <h3 class="font-serif text-[24px] text-gold mb-[16px]">Authenticity Guarantee</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed">
                The black market is chaotic; we are the sovereign. Every timepiece passes through certified Swiss-trained horologists who evaluate movements, papers, and structural integrity before entering the Vault.
            </p>
        </div>

        <!-- Value 3 -->
        <div class="flex flex-col border-t border-gold-faint pt-[32px] group">
            <span class="font-serif-italic text-[64px] text-gold opacity-50 group-hover:opacity-100 transition-opacity duration-600 mb-[16px] leading-none">III.</span>
            <h3 class="font-serif text-[24px] text-gold mb-[16px]">The Indian Collector</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed">
                Built specifically for the subcontinent. We understand the import complexities, the local aesthetic preferences, and the demand for absolute privacy among the Indian elite.
            </p>
        </div>

    </div>
</section>

<!-- TIMELINE (OUR JOURNEY) -->
<section class="py-[128px] max-w-7xl mx-auto border-b border-white-faint px-[32px] overflow-hidden">
    <div class="text-center mb-[80px]">
        <span class="font-sans font-bold text-[12px] text-gold tracking-[3.3px] uppercase">Our Journey</span>
    </div>

    <!-- Timeline Container -->
    <div class="relative w-full">
        <!-- The Horizon Line -->
        <div class="absolute top-[28px] left-[0] right-[0] h-[1px] bg-gold-dim"></div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-[24px] relative z-10 w-full justify-between">
            <!-- 2021 -->
            <div class="flex flex-col items-center text-center">
                <span class="font-sans text-[11px] text-gold tracking-[2px] mb-[12px]">2021</span>
                <!-- The Node -->
                <div class="w-[9px] h-[9px] bg-gold rounded-full mb-[24px] z-10 relative shadow-[0_0_10px_rgba(201,167,74,0.8)]">
                    <div class="absolute inset-0 bg-gold rounded-full animate-ping opacity-20"></div>
                </div>
                <h4 class="font-serif text-[20px] text-white mb-[8px]">The Genesis</h4>
                <p class="font-sans text-[13px] text-muted max-w-[200px]">Established in Mumbai as a private sourcing club.</p>
            </div>

            <!-- 2022 -->
            <div class="flex flex-col items-center text-center">
                <span class="font-sans text-[11px] text-gold tracking-[2px] mb-[12px]">2022</span>
                <div class="w-[9px] h-[9px] bg-gold rounded-full mb-[24px] z-10 relative"></div>
                <h4 class="font-serif text-[20px] text-white mb-[8px]">Global Sourcing</h4>
                <p class="font-sans text-[13px] text-muted max-w-[200px]">Partnerships with Geneva and Tokyo dealers secured.</p>
            </div>

            <!-- 2023 -->
            <div class="flex flex-col items-center text-center">
                <span class="font-sans text-[11px] text-gold tracking-[2px] mb-[12px]">2023</span>
                <div class="w-[9px] h-[9px] bg-gold rounded-full mb-[24px] z-10 relative"></div>
                <h4 class="font-serif text-[20px] text-white mb-[8px]">The App Launch</h4>
                <p class="font-sans text-[13px] text-muted max-w-[200px]">Bringing the digital atelier directly to our clientele.</p>
            </div>

            <!-- 2024 -->
            <div class="flex flex-col items-center text-center">
                <span class="font-sans text-[11px] text-gold tracking-[2px] mb-[12px]">2024</span>
                <div class="w-[9px] h-[9px] bg-gold rounded-full mb-[24px] z-10 relative shadow-[0_0_10px_rgba(201,167,74,0.8)]"></div>
                <h4 class="font-serif text-[20px] text-white mb-[8px]">Wonder Watch</h4>
                <p class="font-sans text-[13px] text-muted max-w-[200px]">Rebranding and opening of the digital showroom.</p>
            </div>
        </div>
    </div>
</section>

<!-- THE CURATORS (TEAM) -->
<section class="py-[128px] px-[32px] md:px-[64px] max-w-7xl mx-auto border-b border-white-faint">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-end mb-[64px] gap-[32px]">
        <h2 class="font-serif text-[48px] md:text-[64px] text-parchment leading-none tracking-[-1.2px]">The Curators</h2>
        <p class="font-sans text-[14px] text-muted max-w-sm text-left md:text-right">
            Guided by decades of horological obsession, our team of curators ensures absolute perfection for the Indian elite.
        </p>
    </div>

    <!-- 3-Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[32px]">
        
        <!-- Member 1 -->
        <div class="group">
            <div class="w-full aspect-[4/5] bg-surface-alt mb-[24px] overflow-hidden">
                <img src="/images/about/curator-1.webp" alt="HARDIK DHARAIYA" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <h4 class="font-serif text-[24px] text-gold mb-[8px]">HARDIK DHARAIYA</h4>
            <span class="font-sans font-bold text-[10px] text-parchment tracking-[2px] uppercase">Lead Senior Developer</span>
        </div>

        <!-- Member 2 -->
        <div class="group">
            <div class="w-full aspect-[4/5] bg-surface-alt mb-[24px] overflow-hidden">
                <img src="/images/about/curator-2.webp" alt="MOHIT YADAV" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <h4 class="font-serif text-[24px] text-gold mb-[8px]">MOHIT YADAV</h4>
            <span class="font-sans font-bold text-[10px] text-parchment tracking-[2px] uppercase">Jr. Developer</span>
        </div>

        <!-- Member 3 -->
        <div class="group">
            <div class="w-full aspect-[4/5] bg-surface-alt mb-[24px] overflow-hidden">
                <img src="/images/about/curator-3.webp" alt="RAM VAROTARIYA" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <h4 class="font-serif text-[24px] text-gold mb-[8px]">RAM VAROTARIYA</h4>
            <span class="font-sans font-bold text-[10px] text-parchment tracking-[2px] uppercase">Frontend Designer</span>
        </div>

    </div>
</section>

<!-- CALL TO ACTION -->
<section class="py-[160px] px-[32px] text-center bg-surface relative overflow-hidden">
    <!-- Faint background element to add depth -->
    <div class="absolute inset-0 bg-gold-faint opacity-5 mix-blend-overlay"></div>
    
    <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center">
        <h2 class="font-serif-italic text-[48px] md:text-[64px] text-parchment leading-none tracking-[-1.5px] mb-[48px]">
            Begin Your Collection.
        </h2>
        
        <a href="/catalog" class="inline-block bg-gold text-void font-sans font-bold text-[13px] tracking-[1.5px] uppercase px-[48px] py-[16px] hover:bg-parchment transition-colors duration-500 rounded-none border border-transparent">
            EXPLORE CATALOG
        </a>
    </div>
</section>