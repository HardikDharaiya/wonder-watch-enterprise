@{
    ViewData["Title"] = "The Houses of Horology";
    ViewData["MetaDescription"] = "Explore Wonder Watch's curated collections by the world's most prestigious horological houses.";
}

<!-- PAGE HEADER (Unbreakable Layout using Inline Styles for Spacing & Watermark) -->
<section class="relative w-full border-b border-white-faint bg-void overflow-hidden flex flex-col items-center justify-center text-center" style="min-height: 55vh; padding-top: 180px; padding-bottom: 80px;">
    
    <!-- Giant XII Watermark (Fixed Opacity and Z-Index using inline styles to bypass JIT compiler issues) -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" style="z-index: 0;">
        <span class="font-serif leading-none tracking-tighter" style="font-size: clamp(200px, 35vw, 450px); color: rgba(255,255,255,0.03); transform: translateY(10px);">XII</span>
    </div>

    <!-- Text Content (Elevated to z-10) -->
    <div class="relative flex flex-col items-center" style="z-index: 10;">
        <span class="font-sans font-bold text-[10px] text-gold tracking-[3.3px] uppercase mb-[24px] block drop-shadow-md">Home / Collections</span>
        <h1 class="font-serif-italic text-[48px] md:text-[64px] lg:text-[80px] text-parchment tracking-[-1.2px] leading-[1.1] mb-[24px] drop-shadow-lg">
            The Houses of Horology.
        </h1>
        <p class="font-sans text-[16px] text-muted leading-relaxed drop-shadow-md">
            Five centuries of craft. One curated destination.
        </p>
    </div>
</section>

