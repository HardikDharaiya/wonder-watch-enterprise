@{
    ViewData["Title"] = "The Concierge";
    ViewData["MetaDescription"] = "Reach out to Wonder Watch's private concierge team. We are available to assist India's most discerning collectors with acquisitions, servicing, and private appointments.";
}

<!-- HERO SECTION -->
<section class="relative w-full border-b border-white-faint bg-void overflow-hidden flex flex-col items-center justify-center text-center" style="min-height: 50vh; padding-top: 136px; padding-bottom: 80px;">
    
    <!-- Subtle watermark -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" style="z-index: 0;">
        <span class="font-serif leading-none tracking-tighter" style="font-size: clamp(160px, 30vw, 400px); color: rgba(255,255,255,0.025);">C.</span>
    </div>

    <div class="relative flex flex-col items-center" style="z-index: 10;">
        <span class="font-sans font-bold text-[10px] text-gold tracking-[3.3px] uppercase mb-[24px] block">Wonder Watch / The Concierge</span>
        <h1 class="font-serif-italic text-[48px] md:text-[72px] lg:text-[88px] text-parchment tracking-[-1.5px] leading-[1.05] mb-[24px]">
            We are<br />at Your Service.
        </h1>
        <p class="font-sans text-[16px] text-muted leading-relaxed max-w-lg mx-auto">
            Speak directly with our private acquisition team. Absolute discretion is not optional — it is our standard.
        </p>
    </div>
</section>

<!-- CONTACT GRID -->
<section class="py-[96px] px-[32px] md:px-[64px] max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[64px] items-start">

        <!-- LEFT: Contact Information -->
        <div class="flex flex-col gap-[48px]">

            <!-- Private Line -->
            <div class="border-t border-gold-faint pt-[32px]">
                <span class="font-sans font-bold text-[10px] text-gold tracking-[2.2px] uppercase mb-[16px] block">Private Acquisition Line</span>
                <a href="tel:+918000000000" class="font-serif text-[32px] text-parchment hover:text-gold transition-colors duration-300 block">+91 80000 00000</a>
                <p class="font-sans text-[13px] text-muted mt-[8px]">Mon – Sat, 10:00 to 20:00 IST</p>
            </div>

            <!-- Secure Email -->
            <div class="border-t border-gold-faint pt-[32px]">
                <span class="font-sans font-bold text-[10px] text-gold tracking-[2.2px] uppercase mb-[16px] block">Encrypted Correspondence</span>
                <a href="mailto:concierge@wonderwatch.in" class="font-serif text-[24px] text-parchment hover:text-gold transition-colors duration-300 block break-all">concierge@wonderwatch.in</a>
                <p class="font-sans text-[13px] text-muted mt-[8px]">Responses within 24 hours. PGP key available on request.</p>
            </div>

            <!-- Atelier Address -->
            <div class="border-t border-gold-faint pt-[32px]">
                <span class="font-sans font-bold text-[10px] text-gold tracking-[2.2px] uppercase mb-[16px] block">Private Atelier</span>
                <p class="font-sans text-[16px] text-parchment leading-relaxed">
                    The Wonder Watch Atelier<br />
                    <span class="text-muted">By Private Appointment Only</span><br />
                    Mumbai, Maharashtra, India
                </p>
                <p class="font-sans text-[13px] text-muted mt-[12px] italic">
                    * Location disclosed upon confirmed appointment.
                </p>
            </div>

            <!-- Response Commitment -->
            <div class="bg-surface border border-gold-faint p-[24px] relative">
                <div class="absolute top-0 left-0 w-6 h-6 border-t border-l border-gold/40 m-3 pointer-events-none"></div>
                <div class="absolute bottom-0 right-0 w-6 h-6 border-b border-r border-gold/40 m-3 pointer-events-none"></div>
                <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase mb-[12px] block">Our Commitment</span>
                <p class="font-sans text-[14px] text-muted leading-relaxed">
                    Every enquiry is treated with the same gravity as the timepieces we curate. We respond personally — never with an automated reply.
                </p>
            </div>

        </div>

        <!-- RIGHT: Enquiry Form -->
        <div class="bg-surface border border-white-faint p-[40px] md:p-[48px] relative">
            <!-- Corner accents -->
            <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-gold/30 m-4 pointer-events-none"></div>
            <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-gold/30 m-4 pointer-events-none"></div>

            <style>
                /* Overwrite browser autofill styles for dark theme */
                input:-webkit-autofill,
                input:-webkit-autofill:hover, 
                input:-webkit-autofill:focus, 
                input:-webkit-autofill:active,
                select:-webkit-autofill,
                select:-webkit-autofill:hover,
                select:-webkit-autofill:focus {
                    -webkit-box-shadow: 0 0 0 30px #1A1A1A inset !important;
                    -webkit-text-fill-color: #F5F0E8 !important;
                    transition: background-color 5000s ease-in-out 0s;
                    caret-color: #C9A74A;
                }
            </style>

            <span class="font-sans font-bold text-[11px] text-gold tracking-[2.2px] uppercase mb-[32px] block">Send an Enquiry</span>

            <form id="contact-form" method="post" action="#" class="flex flex-col gap-[24px]" novalidate>
                @Html.AntiForgeryToken()

                <!-- Name -->
                <div class="flex flex-col gap-[8px]">
                    <label for="contact-name" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Full Name <span class="text-gold">*</span></label>
                    <input
                        type="text"
                        id="contact-name"
                        name="Name"
                        required
                        autocomplete="name"
                        placeholder="Alexander V."
                        class="w-full bg-transparent border-b border-white-faint text-parchment font-sans text-[14px] py-[12px] focus:outline-none focus:border-gold transition-colors rounded-none placeholder-muted/30" />
                </div>

                <!-- Email -->
                <div class="flex flex-col gap-[8px]">
                    <label for="contact-email" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Email Address <span class="text-gold">*</span></label>
                    <input
                        type="email"
                        id="contact-email"
                        name="Email"
                        required
                        autocomplete="email"
                        placeholder="your@email.com"
                        class="w-full bg-transparent border-b border-white-faint text-parchment font-sans text-[14px] py-[12px] focus:outline-none focus:border-gold transition-colors rounded-none placeholder-muted/30" />
                </div>

                <!-- Phone -->
                <div class="flex flex-col gap-[8px]">
                    <label for="contact-phone" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Phone (Optional)</label>
                    <input
                        type="tel"
                        id="contact-phone"
                        name="Phone"
                        autocomplete="tel"
                        placeholder="+91 98765 43210"
                        class="w-full bg-transparent border-b border-white-faint text-parchment font-sans text-[14px] py-[12px] focus:outline-none focus:border-gold transition-colors rounded-none placeholder-muted/30" />
                </div>

                <!-- Subject -->
                <div class="flex flex-col gap-[8px]">
                    <label for="contact-subject" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Nature of Enquiry <span class="text-gold">*</span></label>
                    <select
                        id="contact-subject"
                        name="Subject"
                        required
                        class="w-full bg-surface-alt border-b border-white-faint text-parchment font-sans text-[14px] py-[12px] focus:outline-none focus:border-gold transition-colors rounded-none cursor-pointer appearance-none">
                        <option value="" disabled selected class="text-muted">Select a subject…</option>
                        <option value="acquisition">Private Acquisition Enquiry</option>
                        <option value="sourcing">Custom Sourcing Request</option>
                        <option value="service">Servicing &amp; Maintenance</option>
                        <option value="authentication">Authentication Certificate</option>
                        <option value="appointment">Book Atelier Appointment</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <!-- Message -->
                <div class="flex flex-col gap-[8px]">
                    <label for="contact-message" class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase">Message <span class="text-gold">*</span></label>
                    <textarea
                        id="contact-message"
                        name="Message"
                        required
                        rows="5"
                        placeholder="Describe your acquisition interest, specific references you seek, or any questions…"
                        class="w-full bg-transparent border border-white-faint text-parchment font-sans text-[14px] p-[16px] focus:outline-none focus:border-gold transition-colors rounded-none resize-none placeholder-muted/30"></textarea>
                </div>

                <!-- Disclaimer -->
                <p class="font-sans text-[12px] text-muted leading-relaxed">
                    Your enquiry is handled with complete discretion. We do not share client information with third parties under any circumstance.
                </p>

                <!-- Submit -->
                <button
                    type="submit"
                    id="contact-submit-btn"
                    class="w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.5px] uppercase py-[18px] hover:bg-parchment transition-colors duration-500 focus:outline-none focus:ring-2 focus:ring-gold/50">
                    DISPATCH ENQUIRY
                </button>

                <!-- Success/Error messages (hidden by default) -->
                <div id="contact-success" class="hidden bg-[rgba(201,167,74,0.1)] border border-gold-faint p-[16px] text-center">
                    <span class="font-sans text-[13px] text-gold">Your enquiry has been received. We shall respond within 24 hours.</span>
                </div>
                <div id="contact-error" class="hidden bg-[rgba(255,0,0,0.05)] border border-red-800/30 p-[16px] text-center">
                    <span class="font-sans text-[13px] text-red-400">Something went wrong. Please try again or call us directly.</span>
                </div>

            </form>
        </div>

    </div>
</section>

<!-- FAQ STRIP -->
<section class="py-[80px] px-[32px] md:px-[64px] max-w-[1440px] mx-auto border-t border-white-faint">
    <div class="text-center mb-[64px]">
        <span class="font-sans font-bold text-[10px] text-gold tracking-[3.3px] uppercase">Frequently Asked</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[48px]">

        <div class="border-t border-gold-faint pt-[24px]">
            <h3 class="font-serif text-[18px] text-parchment mb-[12px]">Do you accept trade-ins?</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed">Yes. We evaluate pre-owned timepieces personally. Contact our concierge with photos and documentation for a preliminary assessment.</p>
        </div>

        <div class="border-t border-gold-faint pt-[24px]">
            <h3 class="font-serif text-[18px] text-parchment mb-[12px]">How long does sourcing take?</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed">Rare references typically require 2–8 weeks depending on global availability. We will provide a realistic timeline upon accepting your commission.</p>
        </div>

        <div class="border-t border-gold-faint pt-[24px]">
            <h3 class="font-serif text-[18px] text-parchment mb-[12px]">Are all pieces authenticated?</h3>
            <p class="font-sans text-[14px] text-muted leading-relaxed">Unconditionally. Every timepiece in our catalog has been verified by our in-house horologists, with full documentation and provenance records.</p>
        </div>

    </div>
</section>

@section Scripts {
<script>
    // Contact form UX — prevent default and show success state (real submission requires backend)
    const form = document.getElementById('contact-form');
    const successMsg = document.getElementById('contact-success');
    const errorMsg = document.getElementById('contact-error');
    const submitBtn = document.getElementById('contact-submit-btn');

    if (form) {
        form.addEventListener('submit', async function (e) {
            e.preventDefault();

            // Basic client-side validation
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'DISPATCHING…';

            try {
                const formData = new FormData(form);
                const response = await fetch('/contact', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    successMsg.classList.remove('hidden');
                    errorMsg.classList.add('hidden');
                    submitBtn.textContent = 'ENQUIRY DISPATCHED';
                    submitBtn.classList.replace('bg-gold', 'bg-surface');
                    submitBtn.classList.add('text-gold', 'border', 'border-gold-faint');
                    form.reset(); // Clear form fields upon successful submission
                } else {
                    errorMsg.classList.remove('hidden');
                    if (result.message) {
                        errorMsg.querySelector('span').textContent = result.message;
                    }
                    successMsg.classList.add('hidden');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'DISPATCH ENQUIRY';
                }
            } catch (err) {
                errorMsg.classList.remove('hidden');
                successMsg.classList.add('hidden');
                submitBtn.disabled = false;
                submitBtn.textContent = 'DISPATCH ENQUIRY';
            }
        });
    }
</script>
}
