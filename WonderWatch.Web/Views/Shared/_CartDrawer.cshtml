<!-- CART BACKDROP OVERLAY -->
<div id="cart-backdrop" class="fixed inset-0 bg-void/80 backdrop-blur-sm z-[60] opacity-0 pointer-events-none transition-opacity duration-600"></div>

<!-- CART DRAWER PANEL -->
<aside id="cart-drawer" class="fixed top-0 right-0 h-[100dvh] w-full md:w-[480px] bg-surface border-l border-white-faint z-[70] transform translate-x-full transition-transform duration-600 flex flex-col shadow-2xl">
    
    <!-- DRAWER HEADER -->
    <div class="flex items-center justify-between p-[32px] border-b border-white-faint flex-shrink-0">
        <h2 class="font-serif text-[30px] text-parchment tracking-[-1.5px] leading-none">Your Cart</h2>
        <button id="cart-close-btn" aria-label="Close Cart" class="text-muted hover:text-gold transition-colors focus:outline-none p-2 -mr-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="pointer-events-none">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- DRAWER BODY (Scrollable) -->
    <div class="flex-grow overflow-y-auto p-[32px] relative">
        
        <!-- Empty State -->
        <div id="cart-empty-state" class="absolute inset-0 flex flex-col items-center justify-center text-center p-[32px] hidden">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8A816C" stroke-width="1" stroke-linecap="square" class="mb-[24px]">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <path d="M16 10a4 4 0 01-8 0" />
            </svg>
            <span class="font-sans font-bold text-[11px] text-gold tracking-[2.2px] uppercase mb-[16px] block">Empty</span>
            <p class="font-sans text-[14px] text-muted">Your collection is currently empty. Discover our horological masterpieces.</p>
            <button id="cart-continue-shopping-btn" class="mt-[32px] border-b border-gold text-gold font-sans font-bold text-[11px] tracking-[2.2px] uppercase pb-1 hover:text-parchment hover:border-parchment transition-colors duration-600">
                Explore Catalog
            </button>
        </div>

        <!-- Populated Items Container -->
        <div id="cart-items-container" class="flex flex-col gap-[24px]">
            <!-- Items will be injected here via JS cloning the template below -->
        </div>

    </div>

    <!-- DRAWER FOOTER -->
    <div id="cart-footer" class="p-[32px] border-t border-white-faint bg-surface-alt flex-shrink-0">
        <div class="flex items-center justify-between mb-[24px]">
            <span class="font-sans font-bold text-[12px] text-muted tracking-[1.2px] uppercase">Subtotal</span>
            <span id="cart-subtotal" class="font-sans font-bold text-[20px] text-gold tracking-[-0.45px]">₹0</span>
        </div>
        <p class="font-sans text-[12px] text-muted mb-[24px]">Shipping and taxes calculated at checkout.</p>
        
        <a href="/checkout" id="cart-checkout-btn" class="block w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] text-center hover:bg-parchment transition-colors duration-600 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-surface">
            Proceed to Secure Checkout
        </a>
    </div>

</aside>

<!-- HTML TEMPLATE FOR CART ITEMS (Used by cart.js) -->
<template id="cart-item-template">
    <div class="cart-item flex gap-[16px] pb-[24px] border-b border-white-faint last:border-0 last:pb-0 group">
        
        <!-- Image -->
        <a href="#" class="item-link flex-shrink-0 w-[96px] h-[120px] bg-surface-alt border border-white-faint p-[8px] flex items-center justify-center group-hover:border-gold-faint transition-colors duration-600">
            <img src="" alt="" class="item-image w-full h-full object-contain drop-shadow-lg" />
        </a>
        
        <!-- Details -->
        <div class="flex flex-col flex-grow justify-between py-[4px]">
            <div>
                <div class="flex items-start justify-between gap-[8px]">
                    <span class="item-brand font-sans font-bold text-[9px] text-gold tracking-[2px] uppercase block mb-[4px]">Brand</span>
                    <button type="button" class="item-remove-btn text-muted hover:text-danger transition-colors focus:outline-none" aria-label="Remove item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
                <a href="#" class="item-link font-sans font-medium text-[16px] text-parchment leading-tight hover:text-gold transition-colors line-clamp-2">Watch Name</a>
            </div>
            
            <div class="flex items-end justify-between mt-[12px]">
                <div class="flex items-center border border-white-faint">
                    <span class="font-sans text-[12px] text-muted px-[12px] py-[4px] border-r border-white-faint bg-surface-alt">Qty</span>
                    <span class="item-quantity font-sans font-bold text-[12px] text-parchment px-[12px] py-[4px]">1</span>
                </div>
                <span class="item-total font-sans font-bold text-[14px] text-gold tracking-[-0.45px]">₹0</span>
            </div>
        </div>
    </div>
</template>