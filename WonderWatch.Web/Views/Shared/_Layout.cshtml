@using Microsoft.AspNetCore.Identity
@using WonderWatch.Application.Interfaces
@using WonderWatch.Domain.Identity
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService NotificationService
@{
    // Helper function to determine active navigation state
    string GetActiveNavClass(string path)
    {
        var currentPath = Context.Request.Path.ToString().ToLower();
        if (path == "/") 
        {
            return currentPath == "/" ? "text-gold" : "text-muted";
        }
        if (currentPath.StartsWith(path.ToLower()))
        {
            return "text-gold";
        }
        return "text-muted";
    }

    // Safely check for logged in user and fetch current unread notifications
    var currentUser = await UserManager.GetUserAsync(User);
    var unreadNotificationCount = currentUser != null ? await NotificationService.GetUnreadCountAsync(currentUser.Id) : 0;
}
<!DOCTYPE html>
<html lang="en" class="bg-void text-parchment antialiased">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Wonder Watch</title>
    
    <!-- SEO & OpenGraph Meta Tags -->
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "India's premier dark-luxury watch e-commerce boutique. Discover our curated collection of horological masterpieces.")" />
    <meta property="og:title" content="@ViewData["Title"] — Wonder Watch" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/brand/og-image.webp" />
    
    @await RenderSectionAsync("Meta", required: false)

    <!-- Compiled Tailwind CSS -->
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />

    <!-- Anime.js Animation Library (CDN) -->
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
</head>
<body class="min-h-screen flex flex-col selection:bg-gold selection:text-void bg-void">

    <!-- PUBLIC NAVBAR (72px Height) -->
    <header class="fixed top-0 left-0 w-full h-[72px] z-50 flex items-center justify-between px-[32px] md:px-[64px] transition-all duration-600 bg-transparent border-b border-transparent">
        
        <!-- Left: Mobile Hamburger (Visible only on mobile) -->
        <button id="mobile-menu-toggle" aria-label="Menu" class="lg:hidden text-parchment hover:text-gold transition-colors focus:outline-none z-50">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>

        <!-- Left: Logo & Brand -->
        <a href="/" class="hidden lg:flex items-center gap-[16px] group focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-4 focus:ring-offset-void">
            <svg width="40" height="40" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="transform group-hover:scale-105 transition-transform duration-600">
                <rect width="48" height="48" fill="transparent" />
                <path d="M12 16L24 36L36 16M18 16L24 26L30 16" stroke="#C9A74A" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" />
            </svg>
            <span class="font-sans font-extrabold text-[18px] text-gold tracking-[-1px] uppercase whitespace-nowrap">Wonder Watch</span>
        </a>

        <!-- Center: Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-[48px] absolute left-1/2 transform -translate-x-1/2">
            <a href="/" class="font-sans font-bold text-[12px] @GetActiveNavClass("/") tracking-[1.2px] uppercase hover:text-gold transition-colors focus:outline-none focus:text-gold">Home</a>
            <a href="/collections" class="font-sans font-bold text-[12px] @GetActiveNavClass("/collections") tracking-[1.2px] uppercase hover:text-gold transition-colors focus:outline-none focus:text-gold">Collections</a>
            <a href="/catalog" class="font-sans font-bold text-[12px] @GetActiveNavClass("/catalog") tracking-[1.2px] uppercase hover:text-gold transition-colors focus:outline-none focus:text-gold">Catalog</a>
            <a href="/about" class="font-sans font-bold text-[12px] @GetActiveNavClass("/about") tracking-[1.2px] uppercase hover:text-gold transition-colors focus:outline-none focus:text-gold">About</a>
        </nav>

        <!-- Right: Actions -->
        <div class="flex items-center gap-[16px] md:gap-[24px] lg:gap-[32px] ml-auto lg:ml-0">
            <button id="search-toggle" aria-label="Search" class="text-parchment hover:text-gold transition-colors focus:outline-none focus:text-gold">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                    <circle cx="11" cy="11" r="8" />
                    <path d="M21 21l-4.35-4.35" />
                </svg>
            </button>
            
            <a href="/vault/wishlist" aria-label="Wishlist" class="relative text-parchment hover:text-gold transition-colors focus:outline-none focus:text-gold">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78v0z" />
                </svg>
                <!-- Gold Dot Badge -->
                <span id="nav-wishlist-badge" class="absolute -top-1 -right-1 w-2 h-2 bg-gold rounded-full hidden"></span>
            </a>
            
            <button id="nav-cart-toggle" aria-label="Cart" class="relative text-parchment hover:text-gold transition-colors focus:outline-none focus:text-gold">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 01-8 0" />
                </svg>
                <!-- Gold Dot Badge -->
                <span id="nav-cart-badge" class="absolute -top-1 -right-1 w-2 h-2 bg-gold rounded-full hidden"></span>
            </button>
            
            <a href="/vault/notifications" aria-label="Notifications" class="relative text-parchment hover:text-gold transition-colors focus:outline-none focus:text-gold">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
                @if (unreadNotificationCount > 0)
                {
                    <span class="absolute -top-[6px] -right-[6px] w-[15px] h-[15px] bg-gold rounded-full flex items-center justify-center font-sans font-bold text-[8.5px] text-void leading-none">
                        @(unreadNotificationCount > 9 ? "9+" : unreadNotificationCount.ToString())
                    </span>
                }
            </a>
            
            <a href="/vault" aria-label="Account" class="text-parchment hover:text-gold transition-colors focus:outline-none focus:text-gold">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </a>
        </div>
    </header>

    <!-- MOBILE MENU OVERLAY -->
    <div id="mobile-menu" class="fixed inset-0 bg-void z-[60] transform -translate-y-full transition-transform duration-600 flex flex-col">
        <div class="h-[72px] flex items-center justify-between px-[24px] border-b border-white-faint flex-shrink-0">
            <span class="font-sans font-extrabold text-[16px] text-gold tracking-[-1px] uppercase">Menu</span>
            <button id="mobile-menu-close" aria-label="Close Menu" class="text-parchment hover:text-gold transition-colors focus:outline-none">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <nav class="flex flex-col p-[32px] gap-[32px] flex-grow overflow-y-auto">
            <a href="/" class="font-serif text-[30px] @GetActiveNavClass("/") hover:text-gold transition-colors">Home</a>
            <a href="/collections" class="font-serif text-[30px] @GetActiveNavClass("/collections") hover:text-gold transition-colors">Collections</a>
            <a href="/catalog" class="font-serif text-[30px] @GetActiveNavClass("/catalog") hover:text-gold transition-colors">Catalog</a>
            <a href="/about" class="font-serif text-[30px] @GetActiveNavClass("/about") hover:text-gold transition-colors">About</a>
        </nav>
    </div>

    <!-- SEARCH OVERLAY -->
    <div id="search-overlay" class="fixed inset-0 bg-void/95 backdrop-blur-md z-[60] opacity-0 pointer-events-none transition-opacity duration-600 flex flex-col items-center justify-center px-[24px]">
        <button id="search-close" aria-label="Close Search" class="absolute top-[48px] right-[24px] md:right-[64px] text-muted hover:text-gold transition-colors focus:outline-none">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="square">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        
        <form action="/catalog" method="get" class="w-full max-w-3xl relative">
            <span class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] block text-center">Search the Archives</span>
            <input type="text" name="searchQuery" id="searchInput" placeholder="Enter reference or keyword..." autocomplete="off"
                   class="w-full bg-transparent border-b-2 border-white-faint text-parchment font-serif text-[30px] md:text-[48px] py-[16px] focus:outline-none focus:border-gold transition-colors rounded-none text-center placeholder-muted/30" />
            <button type="submit" class="hidden">Search</button>
        </form>
    </div>

    <!-- MAIN CONTENT -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- PUBLIC FOOTER -->
    <footer class="bg-surface-alt border-t border-white-faint py-[64px] px-[32px] md:px-[64px]">
        <div class="max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[48px] lg:gap-[64px]">
            
            <!-- Column 1: Brand -->
            <div>
                <span class="font-sans font-extrabold text-[20px] text-gold tracking-[-1px] uppercase block mb-[24px]">Wonder Watch</span>
                <p class="font-sans text-[14px] text-muted leading-relaxed">
                    India's premier dark-luxury watch e-commerce boutique. A curated space where every horological masterpiece is treated with the reverence it deserves.
                </p>
            </div>
            
            <!-- Column 2: Client Services -->
            <div>
                <h4 class="font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase mb-[24px]">Client Services</h4>
                <ul class="flex flex-col gap-[16px]">
                    <li><a href="/about" class="font-sans text-[14px] text-muted hover:text-gold transition-colors">The Atelier</a></li>
                    <li><a href="/vault" class="font-sans text-[14px] text-muted hover:text-gold transition-colors">The Vault</a></li>
                    <li><a href="/contact" class="font-sans text-[14px] text-muted hover:text-gold transition-colors">Concierge</a></li>
                </ul>
            </div>
            
            <!-- Column 3: Legal -->
            <div>
                <h4 class="font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase mb-[24px]">Legal</h4>
                <ul class="flex flex-col gap-[16px]">
                    <li><a href="/terms" class="font-sans text-[14px] text-muted hover:text-gold transition-colors">Terms of Service</a></li>
                    <li><a href="/privacy" class="font-sans text-[14px] text-muted hover:text-gold transition-colors">Privacy Policy</a></li>
                    <li><a href="/shipping" class="font-sans text-[14px] text-muted hover:text-gold transition-colors">Shipping & Returns</a></li>
                </ul>
            </div>

            <!-- Column 4: Journal Subscription (NEW) -->
            <div>
                <h4 class="font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase mb-[24px]">Journal Subscription</h4>
                <p class="font-sans text-[14px] text-muted leading-relaxed mb-[24px]">
                    Receive updates on limited edition releases.
                </p>
                <form id="journal-form" class="relative">
                    <input type="email" id="journal-email" name="email" placeholder="YOUR EMAIL ADDRESS" required
                           class="w-full bg-transparent border-b border-white-faint text-parchment font-sans text-[11px] tracking-[1px] uppercase py-[12px] pr-[32px] focus:outline-none focus:border-gold transition-colors rounded-none placeholder-muted/50" />
                    <button id="journal-submit-btn" type="submit" class="absolute right-0 top-1/2 transform -translate-y-1/2 text-gold hover:text-parchment transition-colors focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </button>
                </form>
                <div id="journal-message-container" class="mt-3 hidden">
                    <p id="journal-message" class="font-sans text-[11px] uppercase tracking-[1px]"></p>
                </div>
            </div>

        </div>
        
        <!-- Bottom Copyright Bar -->
        <div class="max-w-[1440px] mx-auto mt-[64px] pt-[32px] border-t border-white-faint flex flex-col md:flex-row items-center justify-between gap-[16px]">
            <p class="font-sans text-[12px] text-muted">&copy; @DateTime.Now.Year Wonder Watch India. All rights reserved.</p>
            <p class="font-sans text-[12px] text-muted">Prices are inclusive of all taxes.</p>
        </div>
    </footer>

    <!-- CART DRAWER PARTIAL -->
    <partial name="_CartDrawer" />

    <!-- GLOBAL SCRIPTS -->
    <script src="~/js/animation.js" type="module" asp-append-version="true"></script>
    <script src="~/js/cart.js" type="module" asp-append-version="true"></script>
    <script src="~/js/wishlist.js" type="module" asp-append-version="true"></script>

    <!-- LAYOUT INTERACTIVITY SCRIPT -->
    <script>
            document.addEventListener('DOMContentLoaded', () => {
                // Mobile Menu Logic
                const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
                const mobileMenuClose = document.getElementById('mobile-menu-close');
                const mobileMenu = document.getElementById('mobile-menu');

                if (mobileMenuToggle && mobileMenuClose && mobileMenu) {
                    mobileMenuToggle.addEventListener('click', () => {
                        mobileMenu.classList.remove('-translate-y-full');
                        document.body.style.overflow = 'hidden';
                    });
                    mobileMenuClose.addEventListener('click', () => {
                        mobileMenu.classList.add('-translate-y-full');
                        document.body.style.overflow = '';
                    });
                }

                // Search Overlay Logic
                const searchToggle = document.getElementById('search-toggle');
                const searchClose = document.getElementById('search-close');
                const searchOverlay = document.getElementById('search-overlay');
                const searchInput = document.getElementById('searchInput');

                if (searchToggle && searchClose && searchOverlay && searchInput) {
                    searchToggle.addEventListener('click', () => {
                        searchOverlay.classList.remove('opacity-0', 'pointer-events-none');
                        document.body.style.overflow = 'hidden';
                        setTimeout(() => searchInput.focus(), 100); // Focus after fade-in
                    });
                    searchClose.addEventListener('click', () => {
                        searchOverlay.classList.add('opacity-0', 'pointer-events-none');
                        document.body.style.overflow = '';
                    });
                }

                // Journal Subscription Form Logic
                const journalForm = document.getElementById('journal-form');
                if (journalForm) {
                    journalForm.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        
                        const emailInput = document.getElementById('journal-email');
                        const submitBtn = document.getElementById('journal-submit-btn');
                        const messageContainer = document.getElementById('journal-message-container');
                        const messageText = document.getElementById('journal-message');
                        
                        const email = emailInput.value.trim();
                        if (!email) return;

                        // UI Loading State
                        submitBtn.disabled = true;
                        submitBtn.style.opacity = '0.5';
                        messageContainer.classList.add('hidden');

                        try {
                            const response = await fetch('/api/journal/subscribe', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ email: email })
                            });

                            const result = await response.json();

                            messageContainer.classList.remove('hidden');
                            if (result.success) {
                                messageText.textContent = result.message;
                                messageText.className = "font-sans text-[11px] uppercase tracking-[1px] text-[#C9A74A]"; // Gold
                                journalForm.reset();
                            } else {
                                messageText.textContent = result.message || "Subscription failed.";
                                messageText.className = "font-sans text-[11px] uppercase tracking-[1px] text-red-500";
                            }
                        } catch (err) {
                            messageContainer.classList.remove('hidden');
                            messageText.textContent = "An error occurred. Please try again.";
                            messageText.className = "font-sans text-[11px] uppercase tracking-[1px] text-red-500";
                        } finally {
                            submitBtn.disabled = false;
                            submitBtn.style.opacity = '1';
                        }
                    });
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>