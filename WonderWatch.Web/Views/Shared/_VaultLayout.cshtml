@using Microsoft.AspNetCore.Identity
@using WonderWatch.Application.Interfaces
@using WonderWatch.Domain.Identity
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService NotificationService
@{
    Layout = "_Layout";

    var currentUser = await UserManager.GetUserAsync(User);
    var unreadCount = currentUser != null ? await NotificationService.GetUnreadCountAsync(currentUser.Id) : 0;
    var avatarUrl = currentUser != null && !string.IsNullOrWhiteSpace(currentUser.AvatarUrl)
        ? currentUser.AvatarUrl
        : (currentUser != null
            ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(currentUser.DisplayName) + "&background=1a1a1a&color=C9A74A&bold=true&size=96&format=svg"
            : "");
    var displayName = currentUser?.DisplayName ?? "Member";
    var fullName = currentUser?.FullName ?? "";
    var memberTier = currentUser?.MembershipTier.ToString() ?? "Silver";
    var memberSince = currentUser?.MemberSince.ToString("MMM yyyy") ?? "";

    // Local function to determine active navigation state
    string GetActiveClasses(string action, string controller = "Vault")
    {
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

        if (string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase))
        {
            return "bg-[rgba(201,167,74,0.08)] border-l-2 border-gold text-gold font-bold";
        }
        return "text-muted font-normal hover:bg-[rgba(255,255,255,0.03)] hover:text-parchment border-l-2 border-transparent";
    }
}

<div class="max-w-7xl mx-auto w-full flex flex-col md:flex-row min-h-[calc(100vh-96px)] mt-[96px] relative">
    
    <!-- MOBILE TOGGLE BAR (Visible only on small screens) -->
    <div class="md:hidden flex items-center justify-between p-[20px] border-b border-white-faint bg-surface/80 backdrop-blur-sm sticky top-[96px] z-[30]">
        <div class="flex items-center gap-[12px]">
            <img src="@avatarUrl" alt="@displayName" class="w-[32px] h-[32px] object-cover border border-gold/30" loading="lazy" />
            <span class="font-sans font-bold text-[12px] text-gold tracking-[1.5px] uppercase">@displayName</span>
        </div>
        <button id="vault-sidebar-toggle" aria-label="Toggle Vault Menu" class="text-parchment hover:text-gold transition-colors focus:outline-none">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- MOBILE BACKDROP -->
    <div id="vault-sidebar-backdrop" class="fixed inset-0 bg-void/80 backdrop-blur-sm z-[40] hidden md:hidden transition-opacity duration-600 opacity-0 pointer-events-none"></div>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- VAULT SIDEBAR (280px Wide) — Premium Editorial Identity Bar   -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <aside id="vault-sidebar" class="fixed md:static top-[96px] left-0 w-[280px] h-[calc(100vh-96px)] md:h-auto bg-void md:bg-transparent border-r border-white-faint flex flex-col z-[50] transform -translate-x-full md:translate-x-0 transition-transform duration-600 overflow-y-auto flex-shrink-0">
        
        <!-- IDENTITY BLOCK — The Heart of the Vault Sidebar -->
        <div class="px-[24px] pt-[32px] pb-[24px] border-b border-white-faint relative">
            <!-- Close button (mobile only) -->
            <button id="vault-sidebar-close" class="md:hidden absolute top-[16px] right-[16px] text-muted hover:text-gold transition-colors focus:outline-none">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>

            <!-- Avatar + Name -->
            <div class="flex items-center gap-[16px] mb-[20px]">
                <div class="relative flex-shrink-0">
                    <img src="@avatarUrl" alt="@displayName" class="w-[56px] h-[56px] object-cover border-2 border-gold/40" loading="lazy" />
                    <!-- Tier indicator dot -->
                    <span class="absolute -bottom-[2px] -right-[2px] w-[14px] h-[14px] bg-gold border-2 border-void flex items-center justify-center">
                        <svg width="8" height="8" viewBox="0 0 24 24" fill="#0A0A0A" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    </span>
                </div>
                <div class="flex flex-col min-w-0">
                    <span class="font-sans font-bold text-[15px] text-parchment leading-tight truncate">@displayName</span>
                    <span class="font-sans text-[11px] text-muted leading-tight mt-[2px] truncate">@fullName</span>
                </div>
            </div>
            
            <!-- Membership Badge - Editorial Style -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-[8px]">
                    <span class="inline-flex items-center gap-[5px] bg-[rgba(201,167,74,0.08)] border border-gold/20 px-[10px] py-[4px]">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        <span class="font-sans font-bold text-[9px] text-gold tracking-[1.8px] uppercase">@memberTier</span>
                    </span>
                </div>
                <span class="font-sans text-[10px] text-muted/50 tracking-[0.5px]">Since @memberSince</span>
            </div>
        </div>

        <!-- NAVIGATION LABEL -->
        <div class="px-[24px] pt-[20px] pb-[8px]">
            <span class="text-[9px] font-sans font-bold tracking-[2.5px] text-muted/30 uppercase">Account Access</span>
        </div>

        <!-- NAVIGATION LINKS -->
        <nav class="flex flex-col gap-[2px] flex-grow px-[8px]">
            
            <a href="/Vault" class="flex items-center gap-[12px] py-[11px] px-[16px] text-[13px] tracking-[0.3px] transition-all duration-300 @GetActiveClasses("Index")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                    <rect x="3" y="3" width="7" height="7" />
                    <rect x="14" y="3" width="7" height="7" />
                    <rect x="14" y="14" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" />
                </svg>
                Dashboard
            </a>

            <a href="/Vault/Orders" class="flex items-center gap-[12px] py-[11px] px-[16px] text-[13px] tracking-[0.3px] transition-all duration-300 @GetActiveClasses("Orders")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                    <line x1="12" y1="22.08" x2="12" y2="12" />
                </svg>
                My Orders
            </a>

            <a href="/Vault/Wishlist" class="flex items-center gap-[12px] py-[11px] px-[16px] text-[13px] tracking-[0.3px] transition-all duration-300 @GetActiveClasses("Wishlist")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78v0z" />
                </svg>
                Wishlist
            </a>

            <a href="/Vault/Profile" class="flex items-center gap-[12px] py-[11px] px-[16px] text-[13px] tracking-[0.3px] transition-all duration-300 @GetActiveClasses("Profile")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
                Profile Settings
            </a>

            <a href="/Vault/Addresses" class="flex items-center gap-[12px] py-[11px] px-[16px] text-[13px] tracking-[0.3px] transition-all duration-300 @GetActiveClasses("Addresses")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
                Addresses
            </a>

            <a href="/Vault/Notifications" class="flex items-center justify-between py-[11px] px-[16px] text-[13px] tracking-[0.3px] transition-all duration-300 @GetActiveClasses("Notifications")">
                <div class="flex items-center gap-[12px]">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    Notifications
                </div>
                @if (unreadCount > 0)
                {
                    <span class="w-[6px] h-[6px] rounded-full bg-[#ef4444]"></span>
                }
            </a>

        </nav>

        <!-- UPGRADE PLAN CTA -->
        <div class="px-[16px] mb-[8px]">
            <a href="/vault/profile#membership"
               class="w-full block font-sans font-bold text-[10px] tracking-[2px] uppercase border border-gold/40 text-gold px-[16px] py-[12px] hover:bg-gold hover:text-void transition-all duration-300 text-center">
                Upgrade Plan
            </a>
        </div>

        <!-- SIGN OUT — Isolated at bottom -->
        <div class="mt-auto pt-[16px] mx-[8px] border-t border-white-faint">
            <form asp-controller="Account" asp-action="Logout" method="post" class="w-full">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-[12px] py-[11px] px-[16px] text-[13px] font-sans font-medium text-[rgba(248,113,113,0.7)] hover:text-[rgba(248,113,113,1)] hover:bg-[rgba(248,113,113,0.05)] transition-all duration-300 text-left focus:outline-none">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Sign Out
                </button>
            </form>
            <div class="px-[16px] pb-[16px] pt-[8px]">
                <span class="font-sans text-[9px] text-muted/20 tracking-[0.5px]">© 2026 Wonder Watch India</span>
            </div>
        </div>

    </aside>

    <!-- VAULT MAIN CONTENT -->
    <div class="flex-grow p-[24px] md:pl-[48px] md:py-[40px] md:pr-[32px] w-full overflow-x-hidden">
        @RenderBody()
    </div>

</div>

<!-- VAULT SIDEBAR INTERACTIVITY SCRIPT -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sidebarToggle = document.getElementById('vault-sidebar-toggle');
        const sidebarClose = document.getElementById('vault-sidebar-close');
        const sidebar = document.getElementById('vault-sidebar');
        const backdrop = document.getElementById('vault-sidebar-backdrop');

        const openSidebar = () => {
            sidebar.classList.remove('-translate-x-full');
            backdrop.classList.remove('hidden');
            setTimeout(() => {
                backdrop.classList.remove('opacity-0', 'pointer-events-none');
                backdrop.classList.add('opacity-100');
            }, 10);
            document.body.style.overflow = 'hidden';
        };

        const closeSidebar = () => {
            sidebar.classList.add('-translate-x-full');
            backdrop.classList.remove('opacity-100');
            backdrop.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => {
                backdrop.classList.add('hidden');
            }, 600);
            document.body.style.overflow = '';
        };

        if (sidebarToggle) sidebarToggle.addEventListener('click', openSidebar);
        if (sidebarClose) sidebarClose.addEventListener('click', closeSidebar);
        if (backdrop) backdrop.addEventListener('click', closeSidebar);
    });
</script>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}