@model WonderWatch.Web.ViewModels.VaultAddressesViewModel
@{
    Layout = "_VaultLayout";
    ViewData["Title"] = "Saved Addresses";
}

<!-- SUCCESS TOAST -->
@if (TempData["AddressSuccess"] != null)
{
    <div id="toast-address" class="fixed top-[112px] right-[24px] z-[100] bg-[rgba(34,197,94,0.15)] border border-[rgba(34,197,94,0.4)] text-[#22c55e] font-sans text-[13px] px-[24px] py-[14px] animate-fadeIn">
        @TempData["AddressSuccess"]
    </div>
}

<div class="mb-[48px] flex flex-col md:flex-row md:items-end justify-between gap-[24px]">
    <div>
        <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">Saved Addresses</h1>
        <p class="font-sans text-[14px] text-muted">Manage your dispatch destinations for seamless acquisitions.</p>
    </div>
    <button type="button" onclick="openAddressModal()" class="bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[16px] hover:bg-parchment transition-colors duration-600 focus:outline-none">
        Add New Address
    </button>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-[32px]">
    
    @if (Model.Addresses.Any())
    {
        @foreach (var addr in Model.Addresses)
        {
            <div class="bg-surface border @(addr.IsDefault ? "border-gold-faint" : "border-white-faint") p-[32px] relative flex flex-col h-full">
                @if (addr.IsDefault)
                {
                    <div class="absolute top-0 right-0 bg-[rgba(201,167,74,0.2)] text-gold font-sans font-bold text-[9px] tracking-[1px] uppercase px-[12px] py-[6px]">
                        Default Shipping
                    </div>
                }
                
                <div class="mb-[24px] pr-[100px]">
                    <h3 class="font-sans font-bold text-[16px] text-parchment mb-[4px]">@addr.FullName</h3>
                    <p class="font-sans text-[14px] text-muted">@addr.Label</p>
                </div>
                
                <div class="flex-grow mb-[32px]">
                    <p class="font-sans text-[14px] text-parchment leading-relaxed">
                        @addr.Line1<br />
                        @if (!string.IsNullOrWhiteSpace(addr.Line2))
                        {
                            @addr.Line2<br />
                        }
                        @addr.City, @addr.State @addr.PinCode<br />
                        @addr.Country
                    </p>
                    <p class="font-sans text-[14px] text-muted mt-[16px]">
                        Phone: @addr.Phone
                    </p>
                </div>
                
                <div class="flex items-center gap-[16px] pt-[24px] border-t border-white-faint">
                    <button type="button" onclick="openEditModal('@addr.Id', '@addr.Label', '@addr.FullName', '@addr.Line1', '@addr.Line2', '@addr.City', '@addr.State', '@addr.PinCode', '@addr.Country', '@addr.Phone', @addr.IsDefault.ToString().ToLower())"
                            class="font-sans font-bold text-[11px] text-gold tracking-[2.2px] uppercase hover:text-parchment transition-colors">
                        Edit
                    </button>
                    <span class="text-white-faint">|</span>
                    @if (!addr.IsDefault)
                    {
                        <form action="/vault/addresses/default/@addr.Id" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase hover:text-gold transition-colors">
                                Set Default
                            </button>
                        </form>
                        <span class="text-white-faint">|</span>
                    }
                    <form action="/vault/addresses/delete/@addr.Id" method="post" class="inline" onsubmit="return confirm('Remove this address?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase hover:text-danger transition-colors">
                            Remove
                        </button>
                    </form>
                </div>
            </div>
        }
    }

    <!-- ADD NEW ADDRESS GHOST CARD -->
    <button type="button" onclick="openAddressModal()" class="bg-transparent border border-dashed border-white-faint hover:border-gold-faint p-[32px] flex flex-col items-center justify-center min-h-[300px] group transition-colors duration-600 focus:outline-none">
        <div class="w-[48px] h-[48px] rounded-full bg-surface-alt border border-white-faint flex items-center justify-center mb-[16px] group-hover:border-gold group-hover:text-gold text-muted transition-colors duration-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
        </div>
        <span class="font-sans font-bold text-[12px] text-parchment tracking-[1.2px] uppercase group-hover:text-gold transition-colors duration-600">
            Add New Destination
        </span>
        <span class="font-sans text-[12px] text-muted mt-[8px]">
            Register a new secure dispatch location.
        </span>
    </button>

</div>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- ADDRESS MODAL — Slide-in panel from right                     -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<div id="address-modal-backdrop" class="fixed inset-0 bg-void/80 backdrop-blur-sm z-[60] hidden opacity-0 transition-opacity duration-600"></div>
<div id="address-modal" class="fixed top-0 right-0 w-full max-w-[480px] h-full bg-void border-l border-white-faint z-[70] transform translate-x-full transition-transform duration-600 overflow-y-auto">
    
    <div class="p-[32px] md:p-[48px]">
        <!-- Header -->
        <div class="flex items-center justify-between mb-[40px]">
            <h2 id="modal-title" class="font-serif text-[28px] text-parchment tracking-[-0.5px]">Add Address</h2>
            <button type="button" onclick="closeAddressModal()" class="text-muted hover:text-gold transition-colors focus:outline-none">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        <!-- Form -->
        <form id="address-form" method="post" class="flex flex-col gap-[24px]">
            @Html.AntiForgeryToken()

            <!-- Label -->
            <div>
                <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Address Type</label>
                <div class="flex gap-[8px]">
                    <label class="flex-1 cursor-pointer">
                        <input type="radio" name="Label" value="Home" checked class="sr-only peer" />
                        <div class="w-full text-center py-[10px] border border-white-faint text-muted font-sans font-bold text-[11px] tracking-[1.5px] uppercase peer-checked:border-gold peer-checked:text-gold peer-checked:bg-[rgba(201,167,74,0.08)] transition-all">Home</div>
                    </label>
                    <label class="flex-1 cursor-pointer">
                        <input type="radio" name="Label" value="Office" class="sr-only peer" />
                        <div class="w-full text-center py-[10px] border border-white-faint text-muted font-sans font-bold text-[11px] tracking-[1.5px] uppercase peer-checked:border-gold peer-checked:text-gold peer-checked:bg-[rgba(201,167,74,0.08)] transition-all">Office</div>
                    </label>
                    <label class="flex-1 cursor-pointer">
                        <input type="radio" name="Label" value="Other" class="sr-only peer" />
                        <div class="w-full text-center py-[10px] border border-white-faint text-muted font-sans font-bold text-[11px] tracking-[1.5px] uppercase peer-checked:border-gold peer-checked:text-gold peer-checked:bg-[rgba(201,167,74,0.08)] transition-all">Other</div>
                    </label>
                </div>
            </div>

            <!-- Full Name -->
            <div>
                <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Full Name</label>
                <input type="text" name="FullName" id="addr-fullname" required
                       class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
            </div>

            <!-- Address Line 1 -->
            <div>
                <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Address Line 1</label>
                <input type="text" name="Line1" id="addr-line1" required placeholder="Street address, P.O. box"
                       class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
            </div>

            <!-- Address Line 2 -->
            <div>
                <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Address Line 2 <span class="text-muted/40">(Optional)</span></label>
                <input type="text" name="Line2" id="addr-line2" placeholder="Apartment, suite, floor"
                       class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
            </div>

            <div class="grid grid-cols-2 gap-[16px]">
                <!-- City -->
                <div>
                    <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">City</label>
                    <input type="text" name="City" id="addr-city" required
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>
                <!-- State -->
                <div>
                    <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">State</label>
                    <input type="text" name="State" id="addr-state" required
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-[16px]">
                <!-- PIN Code -->
                <div>
                    <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">PIN Code</label>
                    <input type="text" name="PinCode" id="addr-pincode" required pattern="[0-9]{6}" maxlength="6"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>
                <!-- Country -->
                <div>
                    <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Country</label>
                    <input type="text" name="Country" id="addr-country" value="India"
                           class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none" />
                </div>
            </div>

            <!-- Phone -->
            <div>
                <label class="font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase mb-[8px] block">Phone Number</label>
                <input type="tel" name="Phone" id="addr-phone" required placeholder="+91 XXXXX XXXXX"
                       class="w-full bg-void border border-white-faint text-parchment font-sans text-[14px] px-[16px] py-[12px] focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors rounded-none placeholder:text-muted/30" />
            </div>

            <!-- Default Toggle -->
            <div class="flex items-center justify-between py-[16px] border-t border-white-faint">
                <span class="font-sans text-[14px] text-parchment">Set as default shipping address</span>
                <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                    <input type="checkbox" name="IsDefault" value="true" id="addr-default" class="sr-only peer">
                    <div class="w-[40px] h-[20px] bg-surface-alt border border-white-faint peer-focus:outline-none peer-focus:ring-1 peer-focus:ring-gold peer-checked:bg-gold peer-checked:border-gold transition-colors duration-300 rounded-none"></div>
                    <div class="absolute left-[2px] top-[2px] bg-muted peer-checked:bg-void w-[16px] h-[16px] transition-transform duration-300 peer-checked:translate-x-[20px] rounded-none"></div>
                </label>
            </div>

            <!-- Submit -->
            <button type="submit" class="w-full bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase py-[18px] hover:bg-parchment transition-colors duration-600 focus:outline-none mt-[8px]">
                Save Address
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openAddressModal() {
        const form = document.getElementById('address-form');
        form.action = '/vault/addresses/add';
        document.getElementById('modal-title').textContent = 'Add Address';
        form.reset();
        document.getElementById('addr-country').value = 'India';
        showModal();
    }

    function openEditModal(id, label, fullName, line1, line2, city, state, pinCode, country, phone, isDefault) {
        const form = document.getElementById('address-form');
        form.action = '/vault/addresses/update/' + id;
        document.getElementById('modal-title').textContent = 'Edit Address';

        document.getElementById('addr-fullname').value = fullName;
        document.getElementById('addr-line1').value = line1;
        document.getElementById('addr-line2').value = line2;
        document.getElementById('addr-city').value = city;
        document.getElementById('addr-state').value = state;
        document.getElementById('addr-pincode').value = pinCode;
        document.getElementById('addr-country').value = country;
        document.getElementById('addr-phone').value = phone;
        document.getElementById('addr-default').checked = isDefault;

        // Set radio
        const radios = form.querySelectorAll('input[name="Label"]');
        radios.forEach(r => r.checked = r.value === label);

        showModal();
    }

    function showModal() {
        const modal = document.getElementById('address-modal');
        const backdrop = document.getElementById('address-modal-backdrop');
        backdrop.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(() => {
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-100');
            modal.classList.remove('translate-x-full');
        });
    }

    function closeAddressModal() {
        const modal = document.getElementById('address-modal');
        const backdrop = document.getElementById('address-modal-backdrop');
        modal.classList.add('translate-x-full');
        backdrop.classList.remove('opacity-100');
        backdrop.classList.add('opacity-0');
        document.body.style.overflow = '';
        setTimeout(() => backdrop.classList.add('hidden'), 600);
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('address-modal-backdrop')?.addEventListener('click', closeAddressModal);

        // Auto-dismiss toasts
        document.querySelectorAll('[id^="toast-"]').forEach(el => {
            setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 600); }, 4000);
        });
    });
</script>
}