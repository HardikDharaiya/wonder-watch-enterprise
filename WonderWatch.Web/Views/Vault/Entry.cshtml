@{
    Layout = "_Layout";
    ViewData["Title"] = "The Vault";
    ViewData["MetaDescription"] = "Discover The Vault by Wonder Watch. An exclusive society for discerning collectors of dark-luxury horology.";
}

<section class="pt-[107px] min-h-screen bg-void flex flex-col lg:flex-row border-b border-white-faint">
    
    <!-- LEFT COLUMN: EDITORIAL IMAGE -->
    <div class="w-full lg:w-1/2 relative min-h-[50vh] lg:min-h-[calc(100vh-107px)] border-b lg:border-b-0 lg:border-r border-white-faint">
        <img src="/images/brand/vault-entry.webp" alt="Inside The Vault" class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125" loading="lazy" />
        
        <!-- Dark Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-void via-void/60 to-transparent"></div>
        
        <!-- Editorial Text Overlay -->
        <div class="absolute bottom-[32px] lg:bottom-[64px] left-[32px] lg:left-[64px] max-w-md z-10">
            <h2 class="font-serif-italic text-[24px] lg:text-[30px] text-parchment leading-tight mb-[16px]">
                "Access is not granted. It is acquired."
            </h2>
            <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase">
                The Inner Circle
            </span>
        </div>
    </div>

    <!-- RIGHT COLUMN: VALUE PROPOSITION & CTAS -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-[32px] md:p-[64px] bg-surface">
        <div class="w-full max-w-lg">
            
            <div class="mb-[48px]">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1" stroke-linecap="square" class="mb-[24px]">
                    <rect x="3" y="11" width="18" height="11" rx="0" ry="0"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
                <h1 class="font-serif text-[48px] md:text-[64px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">The Vault</h1>
                <p class="font-sans text-[14px] text-muted leading-relaxed">
                    A private sanctuary for India's most discerning horological collectors. Membership is strictly curated and offers unprecedented access to our atelier.
                </p>
            </div>

            <!-- Benefits List -->
            <div class="flex flex-col gap-[24px] mb-[48px] py-[32px] border-y border-white-faint">
                
                <div class="flex items-start gap-[16px]">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1.5" stroke-linecap="square" class="flex-shrink-0 mt-1">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    <div>
                        <h3 class="font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase mb-[4px]">Priority Allocation</h3>
                        <p class="font-sans text-[12px] text-muted leading-relaxed">Early access to highly limited references and one-off bespoke creations before they reach the public catalog.</p>
                    </div>
                </div>

                <div class="flex items-start gap-[16px]">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1.5" stroke-linecap="square" class="flex-shrink-0 mt-1">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                    <div>
                        <h3 class="font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase mb-[4px]">Private Sourcing</h3>
                        <p class="font-sans text-[12px] text-muted leading-relaxed">Direct access to our Chief Curator for acquiring specific, hard-to-find references globally.</p>
                    </div>
                </div>

                <div class="flex items-start gap-[16px]">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A74A" stroke-width="1.5" stroke-linecap="square" class="flex-shrink-0 mt-1">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    </svg>
                    <div>
                        <h3 class="font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase mb-[4px]">Portfolio Management</h3>
                        <p class="font-sans text-[12px] text-muted leading-relaxed">Track your acquisitions, manage your wishlist, and view detailed service histories in one secure portal.</p>
                    </div>
                </div>

            </div>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row items-center gap-[16px]">
                <a href="/account/login" class="w-full sm:w-auto flex-grow bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] text-center hover:bg-parchment transition-colors duration-600">
                    Authenticate
                </a>
                <a href="/account/register" class="w-full sm:w-auto flex-grow border border-gold text-gold font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[20px] text-center hover:bg-[rgba(201,167,74,0.1)] transition-colors duration-600">
                    Request Access
                </a>
            </div>

        </div>
    </div>

</section>