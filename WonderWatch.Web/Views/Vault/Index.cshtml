@model WonderWatch.Web.ViewModels.VaultDashboardViewModel
@{
    Layout = "_VaultLayout";
    ViewData["Title"] = "Vault Dashboard";

    // Helper to determine exact badge colors based on Section 3 specs
    string GetBadgeClasses(string status)
    {
        return status.ToUpper() switch
        {
            "PAID" or "PROCESSING" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "SHIPPED" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "DELIVERED" => "bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.2)] text-[#22C55E]",
            "PENDING" => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]",
            "CANCELLED" => "bg-[rgba(127,29,29,0.4)] border border-danger/50 text-danger",
            _ => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]"
        };
    }
}

<!-- GREETING SECTION -->
<div class="mb-[48px]">
    <h1 class="leading-[1.1] tracking-[-1.2px]">
        <span class="font-serif-italic text-[48px] text-parchment/60 uppercase">GOOD @Model.TimeOfDay,</span><br />
        <span class="font-serif font-bold text-[48px] text-parchment uppercase">@Model.FirstName</span>
    </h1>
</div>

<!-- KPI TILES -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-[24px] mb-[64px]">
    
    <div class="bg-surface border border-white-faint p-[32px] flex flex-col justify-between h-[160px]">
        <span class="font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase">Orders</span>
        <span class="font-sans font-light text-[30px] text-gold tracking-[-1.5px]">@Model.OrderCount</span>
    </div>
    
    <div class="bg-surface border border-white-faint p-[32px] flex flex-col justify-between h-[160px]">
        <span class="font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase">Wishlisted</span>
        <span class="font-sans font-light text-[30px] text-gold tracking-[-1.5px]">@Model.WishlistCount</span>
    </div>
    
    <div class="bg-surface border border-white-faint p-[32px] flex flex-col justify-between h-[160px]">
        <span class="font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase">Membership</span>
        <span class="font-sans font-bold text-[18px] text-gold uppercase tracking-[-0.45px]">@Model.MembershipTier</span>
    </div>

</div>

<!-- RECENT ORDER SECTION -->
@if (Model.RecentOrder != null)
{
    <div class="mb-[64px]">
        <span class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] block">Recent Order</span>
        
        <div class="bg-surface border border-white-faint p-[24px] flex flex-col md:flex-row items-start md:items-center gap-[24px]">
            
            <!-- Image (Strictly rounded-none per R-10) -->
            <div class="w-[80px] h-[80px] bg-surface-alt border border-white-faint p-[8px] flex-shrink-0">
                <img src="@Model.RecentOrder.ImageUrl" alt="@Model.RecentOrder.WatchName" class="w-full h-full object-contain drop-shadow-lg" />
            </div>
            
            <!-- Details -->
            <div class="flex flex-col flex-grow">
                <h3 class="font-sans font-medium text-[20px] text-parchment mb-[4px] line-clamp-1">@Model.RecentOrder.WatchName</h3>
                <div class="flex items-center gap-[12px]">
                    <span class="font-mono text-[12px] text-muted">@Model.RecentOrder.OrderNumber</span>
                    <span class="text-white-faint">&bull;</span>
                    <span class="font-sans text-[12px] text-muted">@Model.RecentOrder.Date.ToString("dd MMM yyyy")</span>
                </div>
            </div>
            
            <!-- Price & Status -->
            <div class="flex flex-col items-start md:items-end gap-[8px]">
                <span class="font-sans font-bold text-[18px] text-gold tracking-[-0.45px]">@Model.RecentOrder.TotalFormatted</span>
                <span class="inline-block px-[11px] py-[3px] rounded-[12px] font-sans font-bold text-[10px] tracking-[0.5px] uppercase @GetBadgeClasses(Model.RecentOrder.Status.ToString())">
                    @Model.RecentOrder.Status
                </span>
            </div>
            
            <!-- Actions -->
            <div class="w-full md:w-auto md:ml-[24px] md:pl-[24px] md:border-l border-white-faint flex flex-col gap-[12px]">
                <a href="/vault/orders" class="w-full font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase border border-white-faint px-[24px] py-[12px] hover:text-gold hover:border-gold-faint transition-colors duration-600 text-center whitespace-nowrap">
                    Download Invoice (PDF)
                </a>
            </div>

        </div>
    </div>
}

<!-- YOUR WISHLIST SECTION -->
@if (Model.WishlistPreview.Any())
{
    <div>
        <div class="flex items-center justify-between mb-[24px]">
            <span class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase">Your Wishlist</span>
            <a href="/vault/wishlist" class="font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase hover:text-gold transition-colors">View All &rarr;</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-[24px]">
            @foreach (var watch in Model.WishlistPreview)
            {
                <a href="/catalog/@watch.Slug" class="group block bg-surface border border-white-faint hover:border-gold-faint transition-colors duration-600 flex flex-col h-full relative">
                    
                    @if (watch.IsSoldOut)
                    {
                        <div class="absolute top-4 right-4 z-20 bg-[rgba(127,29,29,0.4)] text-danger font-sans font-bold text-[9px] tracking-[0.9px] uppercase px-[8px] py-[4px]">
                            Sold Out
                        </div>
                    }

                    <div class="w-full aspect-[4/5] bg-surface-alt relative overflow-hidden p-[24px] flex items-center justify-center">
                        <img src="@watch.ImageUrl" alt="@watch.Name" class="w-full h-full object-contain transform group-hover:scale-105 transition-transform duration-600 drop-shadow-2xl" loading="lazy" />
                    </div>
                    
                    <div class="p-[24px] border-t border-white-faint group-hover:border-gold-faint transition-colors duration-600 flex-grow flex flex-col">
                        <span class="font-sans font-bold text-[10px] text-gold tracking-[2px] uppercase block mb-[8px]">@watch.Brand</span>
                        <h3 class="font-sans font-medium text-[20px] text-parchment tracking-normal line-clamp-2">@watch.Name</h3>
                    </div>
                </a>
            }
        </div>
    </div>
}
else
{
    <div>
        <span class="font-sans font-bold text-[11px] text-gold tracking-[3.3px] uppercase mb-[24px] block">Your Wishlist</span>
        <div class="bg-surface border border-white-faint p-[48px] text-center flex flex-col items-center justify-center">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8A816C" stroke-width="1.5" stroke-linecap="square" class="mb-[16px]">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78v0z" />
            </svg>
            <p class="font-sans text-[14px] text-muted mb-[24px]">You have not curated any timepieces yet.</p>
            <a href="/catalog" class="font-sans font-bold text-[11px] text-gold tracking-[2.2px] uppercase border-b border-gold pb-1 hover:text-parchment hover:border-parchment transition-colors duration-600">
                Explore Catalog
            </a>
        </div>
    </div>
}