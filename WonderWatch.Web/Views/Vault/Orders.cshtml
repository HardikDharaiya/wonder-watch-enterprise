@model WonderWatch.Web.ViewModels.VaultOrdersViewModel
@{
    Layout = "_VaultLayout";
    ViewData["Title"] = "Order History";

    // Helper to determine exact badge colors based on Section 3 specs
    string GetBadgeClasses(string status)
    {
        return status.ToUpper() switch
        {
            "PAID" or "PROCESSING" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "SHIPPED" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "DELIVERED" => "bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.2)] text-[#22C55E]",
            "PENDING" => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]",
            "CANCELLED" => "bg-[rgba(127,29,29,0.4)] border border-danger/50 text-danger",
            _ => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]"
        };
    }
}

<div class="mb-[48px]">
    <h1 class="font-serif text-[48px] text-parchment tracking-[-1.2px] leading-none mb-[16px]">Order History</h1>
    <p class="font-sans text-[14px] text-muted">A complete dossier of your acquisitions.</p>
</div>

@if (!Model.Orders.Any())
{
    <div class="bg-surface border border-white-faint p-[64px] text-center flex flex-col items-center justify-center min-h-[400px]">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8A816C" stroke-width="1" stroke-linecap="square" class="mb-[24px]">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
            <line x1="12" y1="22.08" x2="12" y2="12" />
        </svg>
        <h3 class="font-serif text-[24px] text-parchment mb-[8px]">No Acquisitions</h3>
        <p class="font-sans text-[14px] text-muted max-w-md mb-[32px]">
            You have not placed any orders yet. When you acquire a timepiece, its details will appear here.
        </p>
        <a href="/catalog" class="bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[16px] hover:bg-parchment transition-colors duration-600">
            Explore Catalog
        </a>
    </div>
}
else
{
    <div class="flex flex-col gap-[24px]">
        @foreach (var order in Model.Orders)
        {
            <div class="bg-surface border border-white-faint p-[24px] flex flex-col md:flex-row items-start md:items-center gap-[24px] hover:border-gold-faint transition-colors duration-600">
                
                <!-- Image -->
                <div class="w-[96px] h-[96px] bg-surface-alt border border-white-faint p-[8px] flex-shrink-0">
                    <img src="@order.ImageUrl" alt="@order.WatchName" class="w-full h-full object-contain drop-shadow-lg" loading="lazy" />
                </div>
                
                <!-- Details -->
                <div class="flex flex-col flex-grow">
                    <h3 class="font-sans font-medium text-[20px] text-parchment mb-[8px] line-clamp-1">@order.WatchName</h3>
                    <div class="flex flex-wrap items-center gap-[16px] mb-[12px]">
                        <div>
                            <span class="font-sans font-bold text-[9px] text-muted tracking-[2px] uppercase block mb-[2px]">Order No.</span>
                            <span class="font-mono text-[12px] text-gold">@order.OrderNumber</span>
                        </div>
                        <div class="hidden md:block w-[1px] h-[24px] bg-white-faint"></div>
                        <div>
                            <span class="font-sans font-bold text-[9px] text-muted tracking-[2px] uppercase block mb-[2px]">Date</span>
                            <span class="font-sans text-[12px] text-parchment">@order.Date.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="hidden md:block w-[1px] h-[24px] bg-white-faint"></div>
                        <div>
                            <span class="font-sans font-bold text-[9px] text-muted tracking-[2px] uppercase block mb-[2px]">Items</span>
                            <span class="font-sans text-[12px] text-parchment">@order.ItemCount</span>
                        </div>
                    </div>
                </div>
                
                <!-- Price & Status -->
                <div class="flex flex-col items-start md:items-end gap-[12px] md:min-w-[150px]">
                    <span class="font-sans font-bold text-[20px] text-gold tracking-[-0.45px]">@order.TotalFormatted</span>
                    <span class="inline-block px-[11px] py-[3px] rounded-[12px] font-sans font-bold text-[10px] tracking-[0.5px] uppercase @GetBadgeClasses(order.Status.ToString())">
                        @order.Status
                    </span>
                </div>
                
                <!-- Actions -->
                <div class="w-full md:w-auto md:ml-[24px] md:pl-[24px] md:border-l border-white-faint flex flex-col gap-[12px]">
                    <a href="/checkout/confirmation/@order.Id" class="w-full font-sans font-bold text-[11px] text-parchment tracking-[2.2px] uppercase border border-white-faint px-[24px] py-[12px] hover:bg-white-faint transition-colors duration-600 text-center whitespace-nowrap">
                        View Details
                    </a>
                    <a href="#" class="w-full font-sans font-bold text-[11px] text-muted tracking-[2.2px] uppercase border border-transparent px-[24px] py-[12px] hover:text-gold transition-colors duration-600 text-center whitespace-nowrap">
                        Invoice (PDF)
                    </a>
                </div>

            </div>
        }
    </div>
}