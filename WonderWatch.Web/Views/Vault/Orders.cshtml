@model WonderWatch.Web.ViewModels.VaultOrdersViewModel
@{
    Layout = "_VaultLayout";
    ViewData["Title"] = "Order History";

    string GetBadgeClasses(string status)
    {
        return status.ToUpper() switch
        {
            "PAID" or "PROCESSING" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "SHIPPED" => "bg-[rgba(201,167,74,0.2)] border border-[rgba(201,167,74,0.3)] text-gold",
            "DELIVERED" => "bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.2)] text-[#22C55E]",
            "PENDING" => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]",
            "CANCELLED" => "bg-[rgba(127,29,29,0.4)] border border-danger/50 text-danger",
            _ => "bg-[rgba(255,255,255,0.1)] border border-[rgba(255,255,255,0.05)] text-[rgba(255,255,255,0.4)]"
        };
    }

    // Progress tracker step logic based on order status
    int GetActiveStep(string status)
    {
        return status.ToUpper() switch
        {
            "PENDING" => 1,
            "PAID" => 2,
            "PROCESSING" => 3,
            "SHIPPED" => 3,
            "DELIVERED" => 4,
            _ => 0
        };
    }
}

<!-- ============================================================= -->
<!-- PAGE HEADER + SUBTITLE                                         -->
<!-- ============================================================= -->
<div class="mb-[40px]">
    <h1 class="font-serif italic text-[42px] text-parchment tracking-[-1px] leading-none mb-[12px]">
        ORDER HISTORY
    </h1>
    <p class="font-sans text-[13px] text-muted tracking-[0.2px]">
        A complete dossier of your acquisitions.
    </p>
</div>

<!-- ============================================================= -->
<!-- STATUS FILTER TAB STRIP                                        -->
<!-- ============================================================= -->
<div class="flex items-center gap-[32px] mb-[40px] border-b border-white-faint pb-[16px]" id="orderFilterStrip">
    @{
        var filters = new[] { "ALL", "PENDING", "SHIPPED", "DELIVERED" };
    }
    @foreach (var f in filters)
    {
        var isActive = f == (Model.ActiveFilter ?? "ALL");
        <button type="button"
                data-filter="@f"
                class="js-order-filter font-sans font-bold text-[10px] tracking-[2.5px] uppercase pb-[8px] transition-all duration-300 relative
                       @(isActive ? "text-gold" : "text-muted hover:text-parchment")"
                style="@(isActive ? "border-bottom: 2px solid #C9A74A; margin-bottom: -17px; padding-bottom: 16px;" : "border-bottom: 2px solid transparent; margin-bottom: -17px; padding-bottom: 16px;")">
            @f
        </button>
    }
</div>

@if (!Model.Orders.Any())
{
    <!-- ============================================================= -->
    <!-- EMPTY STATE                                                    -->
    <!-- ============================================================= -->
    <div class="bg-surface border border-white-faint p-[64px] text-center flex flex-col items-center justify-center min-h-[400px]">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8A816C" stroke-width="1" stroke-linecap="square" class="mb-[24px]">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
            <line x1="12" y1="22.08" x2="12" y2="12" />
        </svg>
        <h3 class="font-serif text-[24px] text-parchment mb-[8px]">No Acquisitions Yet</h3>
        <p class="font-sans text-[14px] text-muted max-w-md mb-[32px]">
            You have not placed any orders yet. When you acquire a timepiece, its details will appear here.
        </p>
        <a href="/catalog" class="bg-gold text-void font-sans font-bold text-[12px] tracking-[1.2px] uppercase px-[32px] py-[16px] hover:bg-parchment transition-colors duration-600">
            Explore Catalog
        </a>
    </div>
}
else
{
    <!-- ============================================================= -->
    <!-- ORDER CARDS                                                    -->
    <!-- ============================================================= -->
    <div class="flex flex-col gap-[24px]" id="orderCardList">
        @foreach (var order in Model.Orders)
        {
            var statusStr = order.Status.ToString().ToUpper();
            var activeStep = GetActiveStep(statusStr);
            var isCancelled = statusStr == "CANCELLED";

            <div class="js-order-card bg-surface border border-white-faint hover:border-gold-faint transition-colors duration-600"
                 data-status="@statusStr">
                
                <!-- CARD HEADER ROW -->
                <div class="p-[24px] flex flex-col md:flex-row items-start md:items-center gap-[24px]">

                    <!-- Image -->
                    <div style="width: 88px; height: 88px;" class="bg-[#111] border border-white-faint flex-shrink-0 flex items-center justify-center p-[8px]">
                        <img src="@order.ImageUrl" alt="@order.WatchName" class="w-full h-full object-contain" loading="lazy" />
                    </div>

                    <!-- Meta -->
                    <div class="flex-grow min-w-0">
                        <h3 class="font-sans font-medium text-[18px] text-parchment mb-[8px] truncate">@order.WatchName</h3>
                        <div class="flex flex-wrap items-center gap-[12px] text-[12px]">
                            <span class="font-mono text-gold">@order.OrderNumber</span>
                            <span class="text-muted">·</span>
                            <span class="font-sans text-muted">@order.Date.ToString("dd MMM yyyy")</span>
                            <span class="text-muted">·</span>
                            <span class="font-sans text-muted">@order.ItemCount item@(order.ItemCount > 1 ? "s" : "")</span>
                        </div>
                    </div>

                    <!-- Price + Status -->
                    <div class="flex flex-col items-start md:items-end gap-[8px] md:min-w-[160px]">
                        <span class="font-sans font-bold text-[22px] text-gold tracking-[-0.5px]">@order.TotalFormatted</span>
                        <span class="inline-block px-[11px] py-[3px] rounded-[12px] font-sans font-bold text-[10px] tracking-[0.5px] uppercase @GetBadgeClasses(statusStr)">
                            @statusStr
                        </span>
                    </div>

                    <!-- Actions Column -->
                    <div class="w-full md:w-auto md:ml-[8px] md:pl-[24px] md:border-l border-white-faint flex flex-col gap-[8px]">
                        <a href="/checkout/confirmation/@order.Id"
                           class="w-full font-sans font-bold text-[10px] text-parchment tracking-[2px] uppercase border border-white-faint px-[20px] py-[11px] hover:border-gold hover:text-gold transition-all duration-300 text-center whitespace-nowrap">
                            View Details
                        </a>
                        <a href="/vault/orders/@order.Id/invoice" target="_blank"
                           class="w-full font-sans font-bold text-[10px] text-muted tracking-[2px] uppercase border border-transparent px-[20px] py-[11px] hover:text-gold hover:border-gold-faint transition-all duration-300 text-center whitespace-nowrap flex items-center justify-center gap-[6px]">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" class="flex-shrink-0">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14 2 14 8 20 8" />
                                <line x1="16" y1="13" x2="8" y2="13" />
                                <line x1="16" y1="17" x2="8" y2="17" />
                                <polyline points="10 9 9 9 8 9" />
                            </svg>
                            Invoice
                        </a>
                    </div>
                </div>

                <!-- ====================================================== -->
                <!-- 4-STEP PROGRESS TRACKER                                 -->
                <!-- ====================================================== -->
                @if (!isCancelled)
                {
                    <div class="px-[24px] pb-[24px] pt-[8px] border-t border-white-faint">
                        <div class="flex items-start justify-between relative">
                            <!-- Connecting line background -->
                            <div class="absolute top-[14px] left-[14px] right-[14px] h-[2px] bg-white-faint" style="z-index: 0;"></div>
                            <div class="absolute top-[14px] left-[14px] h-[2px] bg-gold transition-all duration-500"
                                 style="z-index: 1; width: @(activeStep switch { 1 => "0%", 2 => "33%", 3 => "66%", 4 or _ => "calc(100% - 28px)" });"></div>

                            @{
                                var steps = new[] {
                                    ("Order Placed", order.Date),
                                    ("Payment Confirmed", activeStep >= 2 ? order.Date : (DateTime?)null),
                                    ("Shipped", activeStep >= 3 ? order.UpdatedAt : (DateTime?)null),
                                    ("Delivered", activeStep >= 4 ? order.UpdatedAt : (DateTime?)null)
                                };
                            }

                            @for (int i = 0; i < steps.Length; i++)
                            {
                                var (label, stepDate) = steps[i];
                                var stepNum = i + 1;
                                var isCompleted = stepNum < activeStep;
                                var isCurrent = stepNum == activeStep;
                                var isFuture = stepNum > activeStep;

                                <div class="flex flex-col items-center relative" style="z-index: 2; width: 25%;">
                                    <!-- Circle -->
                                    @if (isCompleted)
                                    {
                                        <div style="width: 28px; height: 28px;" class="rounded-full bg-gold flex items-center justify-center mb-[8px]">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter">
                                                <polyline points="20 6 9 17 4 12" />
                                            </svg>
                                        </div>
                                    }
                                    else if (isCurrent)
                                    {
                                        <div style="width: 28px; height: 28px;" class="rounded-full border-2 border-gold bg-void flex items-center justify-center mb-[8px]">
                                            <div style="width: 10px; height: 10px;" class="rounded-full bg-gold"></div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="width: 28px; height: 28px;" class="rounded-full border border-white-faint bg-surface flex items-center justify-center mb-[8px]">
                                            <div style="width: 8px; height: 8px;" class="rounded-full bg-[rgba(255,255,255,0.15)]"></div>
                                        </div>
                                    }

                                    <!-- Label -->
                                    <span class="font-sans font-bold text-[9px] tracking-[1.5px] uppercase text-center
                                                 @(isFuture ? "text-[rgba(255,255,255,0.25)]" : "text-parchment")">
                                        @label
                                    </span>

                                    <!-- Date Sub-label -->
                                    @if (stepDate.HasValue && !isFuture)
                                    {
                                        <span class="font-sans text-[10px] text-muted mt-[2px]">
                                            @stepDate.Value.ToString("dd MMM")
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <!-- Cancelled Banner -->
                    <div class="px-[24px] pb-[20px] pt-[12px] border-t border-danger/20">
                        <div class="flex items-center gap-[8px]">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="square">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="15" y1="9" x2="9" y2="15" />
                                <line x1="9" y1="9" x2="15" y2="15" />
                            </svg>
                            <span class="font-sans font-bold text-[10px] tracking-[2px] uppercase text-danger">
                                Order Cancelled
                            </span>
                            <span class="font-sans text-[11px] text-muted ml-[8px]">
                                — @order.UpdatedAt.ToString("dd MMM yyyy")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ============================================================= -->
    <!-- CONCIERGE CTA BLOCK                                            -->
    <!-- ============================================================= -->
    <div class="border border-white-faint bg-surface p-[32px] mt-[48px] flex flex-col md:flex-row justify-between items-start md:items-center gap-[24px]">
        <div>
            <h3 class="font-serif italic text-[18px] text-gold mb-[6px]">Need assistance with an acquisition?</h3>
            <p class="font-sans text-[13px] text-muted">
                Our specialist concierge team is available 24/7 to assist with order inquiries, returns, and watch authentication.
            </p>
        </div>
        <a href="/about#concierge"
           class="flex-shrink-0 border border-gold font-sans font-bold text-[10px] tracking-[2.5px] uppercase text-gold px-[32px] py-[14px] hover:bg-gold hover:text-void transition-all duration-300 text-center whitespace-nowrap">
            Contact Concierge
        </a>
    </div>
}

<!-- ============================================================= -->
<!-- FILTER TAB SCRIPT (client-side switching)                      -->
<!-- ============================================================= -->
<script>
    (function () {
        const btns = document.querySelectorAll('.js-order-filter');
        const cards = document.querySelectorAll('.js-order-card');

        btns.forEach(btn => {
            btn.addEventListener('click', () => {
                const filter = btn.dataset.filter;

                // Update active tab styling
                btns.forEach(b => {
                    b.classList.remove('text-gold');
                    b.classList.add('text-muted');
                    b.style.borderBottomColor = 'transparent';
                });
                btn.classList.remove('text-muted');
                btn.classList.add('text-gold');
                btn.style.borderBottomColor = '#C9A74A';

                // Filter cards
                cards.forEach(card => {
                    const status = card.dataset.status;
                    if (filter === 'ALL' || status === filter) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    })();
</script>