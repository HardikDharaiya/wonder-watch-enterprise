{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:wonderwatch-prod.database.windows.net,1433;Initial Catalog=WonderWatchDb;Persist Security Info=False;User ID=wwadmin;Password=__AZURE_KEY_VAULT_PROVIDED__;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "KeyVault": {
    "VaultUri": "https://kv-wonderwatch-prod.vault.azure.net/"
  },
  "Razorpay": {
    "KeyId": "__AZURE_KEY_VAULT_PROVIDED__",
    "KeySecret": "__AZURE_KEY_VAULT_PROVIDED__"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": "__AZURE_KEY_VAULT_PROVIDED__",
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "ApplicationName": "WonderWatch.Web",
      "Environment": "Production"
    }
  },
  "AllowedHosts": "wonderwatch.in,www.wonderwatch.in",
  "WebOptimizer": {
    "EnableCaching": true,
    "EnableMemoryCache": true,
    "EnableDiskCache": true,
    "AllowEmptyBundle": false
  }
}